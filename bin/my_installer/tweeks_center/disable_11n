#!/bin/sh
iwlwificonf="/etc/modprobe.d/iwlwifi.conf"

if [ "$1" = "--is-enable" ];then
	if find /etc/modprobe.d/ -type f -exec grep -q "^options iwlwifi .*11n_disable=1.*" {} +;then
		exit 0
	else
		exit 1
	fi
fi

say 'disable_11n'
echo 'options iwlwifi 11n_disable=1' | my-superuser tee -a ${iwlwificonf}
