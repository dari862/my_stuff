#!/bin/bash

title_name="yad wget"
icon_name="yadwget"
icon="/usr/share/DmDmDmdMdMdM/images/${icon_name}.png"

function wget_it
{
    [ -z "$1" ] && return
    __links_=${1-}
    [ "$3" == "TRUE" ] && arg1=" -c"
    [ "$4" == "TRUE" ] && arg2=" --no-check-certificate"

	__links_array=($(echo "${__links_}" | sed 's/\\n/ /g'))
	for link in "${__links_array[@]}";do
    	popup_terminal "wget${arg1}${arg2} -t ${2} $link"
    done
}
export -f wget_it

yad --form \
    --no-buttons \
    --title="${title_name}" \
    --window-icon="$icon" \
    --width=400 \
    --height=450 \
    --center \
    --field 'Link(s)':TXT '' \
    --field 'Tries ( -t )':SCL '20' \
    --field '-c':CHK TRUE \
    --field '--no-check-certificate':CHK TRUE \
    --field='Download':FBTN 'bash -c "wget_it %1 %2 %3 %4"'
