#!/bin/sh
# need superuser : use my-superuser
unalias -a
set -e
current_script_name="${0##*/}"
run_reinstall=false
save_2_config_file=true
repobinMODE="bin"
Package_Extension=""
File_to_link=""
user_root_dir=false
repo_to_find="" # Added initialization
link_all_bin=false
create_application_shortcut=false
Post_Installation_Method=""
_SUPERUSER=""

. "$__distro_path_lib"
ROOT_CONFIG_DIR="${__distro_path_neverremove}"
ROOT_INSTALLED_DIR="${ROOT_CONFIG_DIR}/repobin_installed"
ROOT_BIN_DIR="${__distro_path_bin}"
ROOT_CORE_BIN_DIR="${__distro_path_downloaded}/core_hard_link_bins"
ROOT_CORE_DOWNLOAD_DIR="${__distro_path_downloaded}"

USER_CONFIG_DIR="$HOME/.local"
USER_INSTALLED_DIR="${USER_CONFIG_DIR}/repobin_installed"
USER_BIN_DIR="${USER_CONFIG_DIR}/bin"
USER_CORE_BIN_DIR="$USER_CONFIG_DIR/core_hard_link_bins"
USER_CORE_DOWNLOAD_DIR="$USER_BIN_DIR/downloaded"

BIN_DIR=""
CORE_BIN_DIR=""
CORE_DOWNLOAD_DIR=""
CONFIG_DIR=""
INSTALLED_DIR=""
    
while [ "$#" -gt 0 ]; do
  case "$1" in
    --mode) repobinMODE="$2"; shift 2 ;;
    --ext) Package_Extension="$2"; shift 2 ;;
    --file) File_to_link="$2"; shift 2 ;;
    --file-repo) repo_to_find="$2"; shift 2 ;;
    --root) _SUPERUSER="my-superuser"; shift ;;
    --all-bin) link_all_bin=true; shift ;;
    --shortcut) create_application_shortcut=true; shift ;;
    *) break ;;
  esac
done

INFO_COLOR="\033[1;34m"
WARN_COLOR="\033[1;33m"
ERR_COLOR="\033[1;31m"
RESET_COLOR="\033[0m"
BOLD='\033[1m'    
CYAN_COLOR='\033[36m'
GREEN_COLOR='\033[32m'

log()  { printf "${INFO_COLOR}[INFO]${RESET_COLOR} %s\n" "$*"; }
warn() { printf "${WARN_COLOR}[WARN]${RESET_COLOR} %s\n" "$*" >&2; }
err()  { printf "${ERR_COLOR}[ERROR]${RESET_COLOR} %s\n" "$*" >&2 ; exit 1; }

set_main_vars(){
	if [ "$repobinMODE" = "deb" ] || [ "$Package_Extension" = "deb" ];then
		_SUPERUSER="my-superuser"
	fi
	
	if [ "$(id -u)" -eq 0 ] || [ -n "$_SUPERUSER" ]; then
    	user_root_dir=true
    else
    	user_root_dir=false
	fi
	
	if [ "$user_root_dir" = true ]; then
    	[ "$(id -u)" -eq 0 ] && _SUPERUSER=""
    	BIN_DIR="$ROOT_BIN_DIR"
    	CORE_BIN_DIR="$ROOT_CORE_BIN_DIR"
    	CORE_DOWNLOAD_DIR="$ROOT_CORE_DOWNLOAD_DIR"
    	CONFIG_DIR="$ROOT_CONFIG_DIR"
    	INSTALLED_DIR="${ROOT_INSTALLED_DIR}"
	else
    	BIN_DIR="$USER_BIN_DIR"
    	CORE_BIN_DIR="$USER_CORE_BIN_DIR"
    	CORE_DOWNLOAD_DIR="$USER_CORE_DOWNLOAD_DIR"
    	CONFIG_DIR="$USER_CONFIG_DIR"
    	INSTALLED_DIR="${USER_INSTALLED_DIR}"
	fi
	
	if [ ! -d "$BIN_DIR" ];then
		$_SUPERUSER mkdir -p "$BIN_DIR"
	fi
	
	if [ ! -d "$CORE_BIN_DIR" ];then
		$_SUPERUSER mkdir -p "$CORE_BIN_DIR"
	fi
	
	if [ ! -d "$CORE_DOWNLOAD_DIR" ];then
		$_SUPERUSER mkdir -p "$CORE_DOWNLOAD_DIR"
	fi
	
	if [ ! -d "$CONFIG_DIR" ];then
		$_SUPERUSER mkdir -p "$CONFIG_DIR"
	fi
	
	if [ ! -d "$INSTALLED_DIR" ];then
		$_SUPERUSER mkdir -p "$INSTALLED_DIR"
	fi
}

safe_mv() {
  local_ext=".${Package_Extension#.}"
  $_SUPERUSER mv "$tmpfile" "$CORE_DOWNLOAD_DIR/${package_name}${local_ext}"
  $_SUPERUSER chmod +x "$CORE_DOWNLOAD_DIR/${package_name}${local_ext}"
}

Installing_deb() {
  log "Installing deb file."
  INSTALLED_DIR="$ROOT_INSTALLED_DIR"
  [ "$(id -u)" -ne 0 ] && _SUPERUSER="my-superuser"
  [ ! -d "$INSTALLED_DIR" ] && $_SUPERUSER mkdir -p "$INSTALLED_DIR"
  $_SUPERUSER mv "${tmpfile}" "${tmpfile}".deb
  $_SUPERUSER apt-get install -y -f "${tmpfile}".deb
}

mv_appimage() {
  log "appimage detected."
  [ -d "$CORE_DOWNLOAD_DIR/${package_name}.appimage" ] && $_SUPERUSER rm -rf "$CORE_DOWNLOAD_DIR/${package_name}.appimage"
  safe_mv
  cd "$CORE_DOWNLOAD_DIR"
  if ! $_SUPERUSER ./"${package_name}${Package_Extension}" --version >/dev/null 2>&1; then
  	log "Extracting appimage."
      if $_SUPERUSER ./"${package_name}${Package_Extension}" --appimage-extract >/dev/null 2>&1; then
        $_SUPERUSER rm -rf "${package_name}${Package_Extension}"
        $_SUPERUSER mv "squashfs-root" "${package_name}.appimage"
        what_2_ln="${CORE_DOWNLOAD_DIR}/${package_name}.appimage/AppRun"
        where_and_what_2_ln
      fi
  else
      what_2_ln="${CORE_DOWNLOAD_DIR}/${package_name}${Package_Extension}"
      where_and_what_2_ln
  fi
}

where_and_what_2_ln(){
  	where_2_ln="${CORE_BIN_DIR}"
 	log "running ln -sf"
 	log "${what_2_ln}"
 	log "${where_2_ln}"
 	$_SUPERUSER ln -sf "${what_2_ln}" "${where_2_ln}"
}

find_binary_executable() {
  search_dir="$1"
  match_name="$2"
  find "$search_dir" -type f -perm -111 ! -iname "*.so" ! -iname "*.dll" ! -iname "*.1" ! -iname "*.dylib" | grep -i "${match_name:-.}*$" | sort | head -n1
}

extract_and_find_binary() {
  log "extracting binarys from compressed file."
  archive_type="$1"
  found_bin=""
  
  tmpdir="$(mktemp -d /tmp/repobin_XXXXXXXXXXXXXXXXX)"
  tmpdir_extracted="$tmpdir/${package_name}_extracted"
  mkdir -p "$tmpdir_extracted"

  mv "$tmpfile" "${tmpfile}.${archive_type}"
  
  case "$archive_type" in
    zip) unzip -q "${tmpfile}.zip" -d "$tmpdir_extracted" ;;
    tar.gz|tgz) tar -xf "${tmpfile}.${archive_type}" -C "$tmpdir_extracted" ;;
    *) rm -rf "$tmpdir"; err "Unsupported archive type: $archive_type" ;;
  esac

  deb_file=""
  deb_file=$(find "$tmpdir_extracted" -iname "*.deb" | head -n1)
  if [ -n "$deb_file" ]; then
  	log "Found .deb in extracting compressed file."
    tmpfile="$deb_file"
    Post_Installation_Method="deb"
    Installing_deb
    rm -rf "$tmpdir"
    return
  fi
  
  log "archive type are $archive_type"
  
  nested_archive=""
  nested_archive=$(find "$tmpdir_extracted" -type f \( -iname "*.tar.gz" -o -iname "*.tgz" \) | head -n1)
  if [ -n "$nested_archive" ]; then
    log "nested archive file found"
    nested_dir="$tmpdir/nested"
    mkdir -p "$nested_dir"
    tar -xf "$nested_archive" -C "$nested_dir"
    tmpdir_extracted="$nested_dir"
    subdir=""
    subdir="$(find "$tmpdir_extracted" -mindepth 1 -maxdepth 1 -type d)"
    if [ "$(printf '%s\n' "$subdir" | wc -l)" -eq 1 ];then
      tmpdir_extracted="$subdir"
    fi
  fi
  
  found_bin=""
  found_bin=$(find_binary_executable "$tmpdir_extracted" "$File_to_link")
  if [ -z "$found_bin" ]; then
     rm -rf "$tmpdir"
     err "No executable binary found."
  fi
  tmpfile="$found_bin"
  Package_Extension=""
  
  if [ "$repobinMODE" = "bin" ]; then
  	log "repobinMODE are $repobinMODE"
    safe_mv
    what_2_ln="$CORE_DOWNLOAD_DIR/${package_name}${Package_Extension}"
    where_and_what_2_ln
  elif [ "$repobinMODE" = "full" ]; then
  	log "repobinMODE are $repobinMODE"
  	log "Moving ($tmpdir_extracted) to ($CORE_DOWNLOAD_DIR/${package_name}) ."
  	$_SUPERUSER mv "$tmpdir_extracted" "$CORE_DOWNLOAD_DIR/${package_name}"
  	if [ "$link_all_bin" = false ]; then
  		log "link all bin are $link_all_bin"
    	what_2_ln=$(find_binary_executable "$CORE_DOWNLOAD_DIR/${package_name}" "$File_to_link")
    	log "File to link are $File_to_link"
    	$_SUPERUSER chmod +x "$what_2_ln"
    	where_and_what_2_ln
    	extra_bins
  	elif [ "$link_all_bin" = true ]; then
  		log "link all bin are $link_all_bin"
  		$_SUPERUSER find "$CORE_DOWNLOAD_DIR/${package_name}" -type f -perm -111 ! -iname "*.so" ! -iname "*.dll" ! -iname "*.1" ! -iname "*.dylib" -exec ln -sf -t "${CORE_BIN_DIR}" {} +
    	what_2_ln=$(find_binary_executable "$CORE_DOWNLOAD_DIR/${package_name}" "$File_to_link")
    	extra_bins
  	fi
  fi
  rm -rf "$tmpdir"
}

verify_checksum() {
  bin_path="$1"
  checksum_url="$2"
  tmp_checksum=""
  expected=""
  actual=""

  tmp_checksum="$(mktemp /tmp/repobin_XXXXXXXXXXXXXXXXX)"
  getURL "download2" "$checksum_url" "$tmp_checksum"
  basename_bin_path="${bin_path##*/}"
  expected=$(grep "$basename_bin_path" "$tmp_checksum" | awk '{print $1}')
  if [ -z "$expected" ]; then
    warn "Checksum file does not include $basename_bin_path"
    rm -f "$tmp_checksum"
    return
  fi

  actual=$(sha256sum "$bin_path" | awk '{print $1}')
  if [ "$expected" != "$actual" ]; then
    rm -f "$tmp_checksum"
    err "Checksum mismatch! Expected: $expected, Actual: $actual"
  fi

  log "Checksum verified for $basename_bin_path"
  rm -f "$tmp_checksum"
}

select_assets() {
  OS=""
  uname_ARCH=""
  ARCH=""
  assets=""
  filtered_assets=""
  appimage_assets=""

  OS="$(uname -s)"
  uname_ARCH="$(uname -m)"
  case "$uname_ARCH" in
    x86_64)   ARCH="x86_64|amd64|x86-64|_x64_" ;;
    aarch64) ARCH="aarch64|arm64"              ;;
    armv7*)  ARCH="armv7"                      ;;
  esac
  
  assets="$(printf '%s\n' "${all_assets}")"
  
  if [ -n "$ARCH" ] && printf '%s\n' "${assets}" | grep -iqE "${ARCH}" ; then
      assets="$(printf '%s\n' "${assets}" | grep -iE "${ARCH}")"
  fi
  if printf '%s\n' "${assets}" | grep -iqE "${OS}" ; then
    assets="$(printf '%s\n' "${assets}" | grep -i "${OS}")"
  fi
  if [ -n "$repo_to_find" ] && printf '%s\n' "${assets}" | grep -iqE "${repo_to_find}" ; then
    assets="$(printf '%s\n' "${assets}" | grep -i "${repo_to_find}")"
  fi
  
  if [ -n "$Package_Extension" ]; then
    filtered_assets="$(printf '%s\n' "${assets}" | grep -i "$Package_Extension")"
  elif [ "$Package_Extension" != "appimage" ]; then
    filtered_assets="$(printf '%s\n' "${assets}" | grep -v "appimage")"
  else
    filtered_assets="${assets}"
  fi
  
  if printf '%s\n' "${assets}" | grep -qi "appimage"; then
      appimage_assets="$(printf '%s\n' "${assets}" | grep -i "appimage")"
  fi
  
  picked_assets=""
  if [ -n "$filtered_assets" ]; then
      picked_assets="$filtered_assets"
  elif [ -n "$appimage_assets" ]; then
      picked_assets="$appimage_assets"
  fi
    
  for url in $picked_assets; do
      case "$url" in
          *sha256*) [ -z "$checksum_url" ] && checksum_url="$url" ;;
          *) [ -z "$asset_url" ] && asset_url="$url" ;;
      esac
      if [ -n "$asset_url" ] && [ -n "$checksum_url" ]; then
          break
      fi
  done
}

install_repo() {
  release_json=""
  
  if [ -z "$Package_Version" ]; then
    release_json=$(getURL "2term" "https://api.github.com/repos/$Remote_Repo/releases/latest")
    Package_Version=$(printf '%s\n' "$release_json" | jq -r '.tag_name')
  else
    release_json=$(getURL "2term" "https://api.github.com/repos/$Remote_Repo/releases/tags/$Package_Version")
  fi
  
  if [ "$(printf '%s\n' "$release_json" | jq -r '.draft')" = true ] || [ "$(printf '%s\n' "$release_json" | jq -r '.prerelease')" = true ]; then
    warn "Release is draft or prerelease. Skipping."; return 1
  fi
  all_assets="$(printf '%s\n' "$release_json" | jq -r '.assets[].browser_download_url' | grep -vE '\.zsync|\.changes$')"
  select_assets

  [ -z "$asset_url" ] && err "No matching asset found."
  [ "$run_reinstall" = false ] && [ -f "$BIN_DIR/${package_name}${Package_Extension}" ] && err "Repo already installed."

  tmpfile=$(mktemp /tmp/repobin_XXXXXXXXXXXXXXXXX)
  log "Downloading from $asset_url"
  getURL "download2" "$asset_url" "$tmpfile"

  [ -n "$checksum_url" ] && verify_checksum "$tmpfile" "$checksum_url"
  
  lower_asset_url=$(printf '%s\n' "$asset_url" | tr '[:upper:]' '[:lower:]')
  what_2_do=""
  Package_Extension="${lower_asset_url##*.}"
  case "$lower_asset_url" in
    *.deb) what_2_do="deb" ;;
    *.appimage) what_2_do="appimage" ;;
    *.zip) what_2_do="zip" ;;
    *.tar.gz|*.tgz) what_2_do="tgz" ;;
    *) what_2_do="else" ;;
  esac
  
  log "what_2_do = $what_2_do"
  
  Installation_Method="$what_2_do"
  
  if [ "$what_2_do" = "deb" ];then
  	Installing_deb
  else
  	log "Running function related to $what_2_do"
    case "$what_2_do" in
    	appimage) mv_appimage ;;
    	zip) extract_and_find_binary "zip" ;;
    	tgz) extract_and_find_binary "tar.gz" ;;
    	else) safe_mv
    		  what_2_ln="$CORE_DOWNLOAD_DIR/${package_name}${Package_Extension}"
    		  where_and_what_2_ln
    	;;
  	esac
  	
  	for f in "${CORE_BIN_DIR}"/*;do
  		$_SUPERUSER ln -sf "${f}" "${BIN_DIR}"
  	done
  fi
  
  if [ "$create_application_shortcut" = true ];then
  	. "${__distro_path_root}/lib/common/common"
  	generate_applicationsdotdesktop_link "${package_name}" "${package_name}" "${package_name}"
  fi
  
  log "Installed $package_name@$Package_Version"
  save_config
  exit
}

update() {
  for package in "${INSTALLED_DIR}"/*;do
    if [ -z "$package" ];then
    	continue
    else
    	package_name="${package##*/}"
    	. "$package"
    fi
    log "Checking $package_name..."

  done
}

update() {
    _update_packages() {
        (
            dir="${1:-}"
            title="${2:-}"
            _SUPERUSER="${3:-}"
            
			package=""
			
            # POSIX way to check if a directory contains files matching the glob
            # If the glob doesn't expand, the literal string containing '*' is evaluated
            set -- "$dir"/*
            if [ ! -e "$1" ]; then
                return 0
            fi
            
            printf '\n%b%s%b\n' "${BOLD}${INFO_COLOR}" "$title" "${RESET_COLOR}"
            printf '%b======================================%b\n' "${INFO_COLOR}" "${RESET_COLOR}"
            
            set_main_vars
            
            for package in "$dir"/*; do
                [ -e "$package" ] || continue
                
                if [ -r "$package" ]; then
                    . "$package"
                else
                    printf '%bWarning: Cannot read %s%b\n' "${ERR_COLOR}" "$package" "${RESET_COLOR}" >&2
                    continue
                fi
                
                package_name="${package##*/}"
                
                log "Checking $package_name..."
                release_json=""
    			release_json=$(getURL "2term" "https://api.github.com/repos/$Remote_Repo/releases/latest")
			
    			if [ "$(printf '%s\n' "$release_json" | jq -r '.draft')" = "true" ] || [ "$(printf '%s\n' "$release_json" | jq -r '.prerelease')" = "true" ]; then
      				warn "Latest release is draft/prerelease. Skipping."
      				continue
    			fi
			
    			latest_version=$(printf '%s\n' "$release_json" | jq -r '.tag_name')
  				if [ "$Package_Version" = "$latest_version" ];then
   					log "$Remote_Repo are up to date."
  				else
  					log "Updating $Remote_Repo: $Package_Version → $latest_version"
      				install_repo
      				save_config
  				fi
            done
        )
    }

    # Call the helper function
    _update_packages "$ROOT_INSTALLED_DIR" "Packages Installed by Root" "my-superuser"
    _update_packages "$USER_INSTALLED_DIR" "Packages Installed by $USER" ""
}

list_installed() {
    _print_packages() {
        (
            dir="$1"
            title="$2"
			package=""
            # POSIX way to check if a directory contains files matching the glob
            # If the glob doesn't expand, the literal string containing '*' is evaluated
            set -- "$dir"/*
            if [ ! -e "$1" ]; then
                return 0
            fi
            
            printf '\n%b%s%b\n' "${BOLD}${INFO_COLOR}" "$title" "${RESET_COLOR}"
            printf '%b======================================%b\n' "${INFO_COLOR}" "${RESET_COLOR}"
            
            for package in "$dir"/*; do
                [ -e "$package" ] || continue
                
                if [ -r "$package" ]; then
                    . "$package"
                else
                    printf '%bWarning: Cannot read %s%b\n' "${ERR_COLOR}" "$package" "${RESET_COLOR}" >&2
                    continue
                fi
                
                package_name="${package##*/}"
                
                printf '%b┌─── Package: %b%s%b\n' "${CYAN_COLOR}" "${BOLD}${GREEN_COLOR}" "$package_name" "${RESET_COLOR}"
                printf '%b│%b\n' "${CYAN_COLOR}" "${RESET_COLOR}"
                
                current_package_info
                
                printf '%b└───%b\n\n' "${CYAN_COLOR}" "${RESET_COLOR}"
            done
        )
    }

    # Call the helper function
    _print_packages "$ROOT_INSTALLED_DIR" "Packages Installed by Root"
    _print_packages "$USER_INSTALLED_DIR" "Packages Installed by $USER"
}

save_config() {
    [ "$save_2_config_file" = false ] && return
    {
    	printf 'Remote_Repo="%s"\n' "$Remote_Repo"
  		printf 'Package_Version="%s"\n' "$Package_Version"
  		printf 'Package_Extension="%s"\n' "$Package_Extension"
  		printf 'Installation_Method="%s"\n' "$Installation_Method"
  		printf 'Post_Installation_Method="%s"\n' "$Post_Installation_Method"
  	} | $_SUPERUSER tee "${INSTALLED_DIR}/${package_name}" 1>/dev/null
    log "Done."
}

remove_installed() {
  target="$CORE_DOWNLOAD_DIR/$package_name"
  
  if [ "$Installation_Method" = "deb" ] || [ "$Post_Installation_Method" = "deb" ]; then
    $_SUPERUSER apt-get purge -y "${package_name}"
  elif [ -f "$target" ]; then
    $_SUPERUSER rm -rdf "$target"
    log "Removed binary: $target"
  elif [ -d "$target" ]; then
    $_SUPERUSER rm -rdf "$target"
    log "Removed Dir: $target"
  else
    warn "Binary file/dir not found: $target"
  fi
  $_SUPERUSER rm -rdf "${INSTALLED_DIR}/${package_name}"
  log "Removed $Remote_Repo from config"
  exit
}

current_package_info(){
  print_package_info() {
  	varname="$1"
  	varvalue="$2"
  	printf '%b%s:%b %s\n' "${BOLD}${WARN_COLOR}" "$varname" "${RESET_COLOR}" "$varvalue"
  }
  
  print_package_info 'Repository' "$Remote_Repo"
  print_package_info 'Installed Version' "$Package_Version"
  print_package_info 'Installed Extenstion' "$Package_Extension"
  print_package_info 'Installation Method' "$Installation_Method"
}

info_installed() {
  current_package_info
  release_json=""
  release_json=$(getURL "2term" "https://api.github.com/repos/$Remote_Repo/releases/latest") || {
    warn "Failed to fetch release info"
    return 1
  }

  latest_version=$(printf '%s\n' "$release_json" | jq -r '.tag_name')
  if [ "$Package_Version" = "$latest_version" ];then
   log "$Remote_Repo are up to date."
  else
  	warn 'Latest Release Version are: %s\n' "$latest_version"
  fi
  exit
}

clean_installed() {
  $_SUPERUSER rm -rf /tmp/repobin_*
  log "Removed temp file."
}

print_help() {
  cat <<EOF
Usage: ${current_script_name} [OPTIONS] <COMMAND> [ARGS...]
    
   ${current_script_name} [--root] [--ext extension] install <user/repo> [version]
   ${current_script_name} [--root] update
   
Options:
  --root                Use my-superuser when installing to protected paths

Commands:
  install <user/repo>   Install a GitHub release binary
  update                Update all installed binaries to latest versions
  list                  List installed binaries and their versions
  remove <user/repo>    Remove installed binary and update config
  info <user/repo>      Show installed and latest release version info
  clean                 Clean temporary files generated by the script
  reinstall <user/repo> Reinstall a specific binary
  help                  Show this help message
EOF
}

set_main_vars

COMMAND="${1:-}"
shift || true

if [ -n "${1:-}" ] && [ "${COMMAND}" = "install" ]; then
    case "${1}" in
        */*) log "normal mode."
             Remote_Repo="${1:-}"
             package_name="${Remote_Repo##*/}"
             Package_Version="${2:-}"
             extra_bins() { :; }
          ;;
        *)   log "Getting date from repobin lib."
        	 package_name="${1:-}"
             package_details_file_2_source="${__distro_path_root}/lib/${current_script_name}/${package_name}.sh"
             if [ -f "${package_details_file_2_source}" ]; then
                 . "${package_details_file_2_source}"
             else
                 err "failed to install: ${package_name} . does not exist in ${current_script_name} lib."
             fi
          ;;
    esac
    
    if [ -z "${package_name}" ];then
    	err "Usage: ${current_script_name} install <user/repo>"
    elif [ -f "${INSTALLED_DIR}/${package_name}" ];then
    	err "Repo installed: $Remote_Repo to reinstall it switch to reinstall arg."
    fi
    install_repo
fi

if [ -n "${1:-}" ] && { [ "${COMMAND}" = "remove" ] || [ "${COMMAND}" = "reinstall" ] || [ "${COMMAND}" = "info" ]; }; then
    case "${1}" in
        */*) log "normal mode."
             package_name="${1##*/}"
          ;;
        *)   log "Getting date from repobin lib."
        	 package_name="${1:-}"
          ;;
    esac
    
    if [ ! -f "${INSTALLED_DIR}/${1}" ];then
    	err "No such repo installed: ${1}"
    else
    	. "${INSTALLED_DIR}/${1}"
    fi
    
    if [ "${COMMAND}" = "remove" ];then
    	remove_installed
    elif [ "${COMMAND}" = "reinstall" ];then
    	run_reinstall=true
    	save_2_config_file=false
    	log "Reinstalling $Remote_Repo@$Package_Version"
    	install_repo
    elif [ "${COMMAND}" = "info" ];then
    	info_installed
    fi
fi

if [ -z "${1:-}" ] && { [ "${COMMAND}" = "remove" ] || [ "${COMMAND}" = "reinstall" ] || [ "${COMMAND}" = "info" ]; }; then
	err "Usage: ${current_script_name} ${COMMAND} <user/repo>"
fi

case "$COMMAND" in
  update) run_reinstall=true ; update ;;
  list) list_installed ;;
  clean) clean_installed ;;
  help|-h|--help) print_help ;;
  *) print_help ; err "Unknown command: $COMMAND" ;;
esac
