# @TODO: finish replacing the colors here


# Menu
menu.border.color: {foreground}

menu.title.bg: Solid Flat
menu.title.bg.color: {cursor}
menu.title.bg.shadow: 0
menu.title.text.color: {foreground}
menu.title.text.justify: Center

menu.items.bg: Solid Flat
menu.items.bg.color: {cursor}
menu.items.text.color: {foreground}
menu.items.disabled.text.color: #aeb4be

menu.items.active.bg: Solid Flat
menu.items.active.bg.color: {color3}
menu.items.active.text.color: {foreground}

menu.separator.color: #aeb4be
menu.separator.width: 1
menu.separator.padding.width: 2
menu.separator.padding.height: 4

# Window focused
window.active.title.separator.color: {cursor}

# Active window
window.active.border.color: {background}


window.active.title.bg: flat solid
window.active.title.bg.color: {cursor}
window.active.title.separator.color: {cursor}
window.active.text.justify: center

window.active.label.bg: parentrelative
window.active.label.text.color: {foreground}

window.active.handle.bg: flat solid
window.active.handle.bg.color: {cursor}

window.active.grip.bg: flat solid
window.active.grip.bg.color: {cursor}

window.active.button.unpressed.bg: flat solid
window.active.button.unpressed.bg.color: {cursor}
window.active.button.unpressed.image.color: {foreground}

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: {color3}
window.active.button.pressed.image.color: {foreground}

window.active.button.disabled.bg: flat solid
window.active.button.disabled.bg.color: {cursor}
window.active.button.disabled.image.color: #aeb4be

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: {cursor}
window.active.button.hover.image.color: {color3}

#window.active.button.toggled.bg: {color3}
#window.active.button.toggled.image.color: {foreground}

# Inactive window
window.inactive.border.color: {background}

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: {cursor}
window.inactive.title.separator.color: {cursor}
window.inactive.text.justify: center

window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #aeb4be

window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: {cursor}

window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: {cursor}

window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: {cursor}
window.inactive.button.unpressed.image.color: #aeb4be

window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: {color3}
window.inactive.button.pressed.image.color: {foreground}

window.inactive.button.disabled.bg: flat solid
window.inactive.button.disabled.bg.color: #aeb4be
window.inactive.button.disabled.image.color: {cursor}

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: {cursor}
window.inactive.button.hover.image.color: {color3}


# OSD
osd.border.width: 1
osd.border.color: {color3}

osd.bg: flat solid
osd.bg.color: {cursor}
osd.label.bg: flat solid
osd.label.bg.color: {cursor}
osd.label.text.color: {foreground}

# OSD
osd.bg: Solid Flat
osd.bg.color: {cursor}
osd.bg.shadow: 0

osd.border.width: 2
osd.hilight.bg: Solid Flat
osd.hilight.bg.color: {color3}
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: {background}

osd.button.unpressed.bg: flat border
osd.button.unpressed.bg.color: {cursor}
#osd.button.unpressed.*.border.color: {foreground}

osd.button.pressed.bg: flat border
osd.button.pressed.bg.color: {color3}
#osd.button.pressed.*.border.color: {foreground}

osd.button.focused.bg: flat solid border
osd.button.focused.bg.color: {foreground}
#osd.button.focused.*.border.color: {background}

osd.button.focused.box.color: {color3}


# Fonts
window.active.label.text.font:shadow=n
window.inactive.label.text.font:shadow=n
menu.items.font:shadow=n
menu.title.text.font:shadow=n


# Everything else
border.width: 2
padding.width: 8
padding.height: 2
window.handle.width: 0
window.client.padding.width: 0
window.label.text.justify: center
#menu.overlap: 0
