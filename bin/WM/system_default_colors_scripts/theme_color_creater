#!/bin/bash
style="${1:-}"
temp_theme_file_dir="${2:-/tmp/$USER/theme_color_creater_output}"
theme_file_2_source="${temp_theme_file_dir}/temp_${style}_colors.sh"

if [ -z "${style}" ]; then
    echo "style = ${style} , does not exist."
    exit 1
fi

if [ -z "${theme_file_2_source}" ]; then
    echo "[ERROR] $0: theme_file_2_source = ${theme_file_2_source}."
    exit 1
fi

convert_hex_to_rgb_with_backspace() {
    hex=$1
    hex="${hex//\#}"
    
    # Extract the two-digit hex values and convert to decimal
    r="${hex:0:2}"
    g="${hex:2:2}"
    b="${hex:4:2}"
    
    echo "$r/$g/$b/ff"
}

convert_hex_to_rgb() {
    hex=$1
    hex="${hex//\#}"  # Remove the '#' symbol if present

    # Extract the two-digit hex values
    r="${hex:0:2}"
    g="${hex:2:2}"
    b="${hex:4:2}"

    # Convert each hex component to decimal using printf
    printf "%d,%d,%d\n" "$((16#$r))" "$((16#$g))" "$((16#$b))"
}

current_script_path="$(cd "$(dirname "$0")"; pwd)"

# Remove temp theme file directory if it exists
[ -d "$temp_theme_file_dir" ] && rm -rdf "$temp_theme_file_dir"

# Copy templates to the temporary directory
cp -r "${current_script_path}/templates" "$temp_theme_file_dir"

# Create palette if the theme file doesn't exist
if [ ! -f "$theme_file_2_source" ]; then
    "${current_script_path}"/palette_creator "$theme_file_2_source"
fi

# Source the theme file
if ! . "${theme_file_2_source}"; then
    echo "[ERROR] $0: failed to source ${theme_file_2_source}"
    exit 1
fi

[ -z "$alpha" ] && alpha="100"

background_rgb="$(convert_hex_to_rgb $background_rgb)"
foreground_rgb="$(convert_hex_to_rgb $foreground_rgb)"
cursor_rgb="$(convert_hex_to_rgb $foreground_rgb)"
color0_rgb="$(convert_hex_to_rgb $color0_rgb)"
color1_rgb="$(convert_hex_to_rgb $color1_rgb)"
color2_rgb="$(convert_hex_to_rgb $color2_rgb)"
color3_rgb="$(convert_hex_to_rgb $color3_rgb)"
color4_rgb="$(convert_hex_to_rgb $color4_rgb)"
color5_rgb="$(convert_hex_to_rgb $color5_rgb)"
color6_rgb="$(convert_hex_to_rgb $color6_rgb)"
color7_rgb="$(convert_hex_to_rgb $color7_rgb)"
color8_rgb="$(convert_hex_to_rgb $color8_rgb)"
color9_rgb="$(convert_hex_to_rgb $color9_rgb)"
color10_rgb="$(convert_hex_to_rgb $color10_rgb)"
color11_rgb="$(convert_hex_to_rgb $color11_rgb)"
color12_rgb="$(convert_hex_to_rgb $color12_rgb)"
color13_rgb="$(convert_hex_to_rgb $color13_rgb)"
color14_rgb="$(convert_hex_to_rgb $color14_rgb)"
color15_rgb="$(convert_hex_to_rgb $color15_rgb)"

color15_xrgba="$(convert_hex_to_rgb_with_backspace $color15)"

find "$temp_theme_file_dir" -type f -exec sed -i "s/{alpha}/${alpha}/g" {} +

