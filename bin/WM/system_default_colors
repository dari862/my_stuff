#!/bin/bash
__opt="${1:-}"
style_name="${2:-}"
if [ -z "${__opt}" ];then
	echo "__opt = ${__opt} no option."
	exit 1
fi

if [ -z "${style_name}" ];then
	echo "style_name = ${style_name} , does not exist."
	exit 1
fi

theme_file_name="theme_file_2_source"
theme_file_2_source="/tmp/$USER/$theme_file_name"

if [ "$__opt" = "--clean" ];then
	theme_color_creater --clean "${theme_file_2_source}"
fi

if [ ! -f "$theme_file_2_source" ];then
	theme_color_creater --create "$theme_file_2_source"
fi

. "/usr/share/my_stuff/lib/common/WM"
. "/usr/share/my_stuff/lib/common/panel"
	
home_config_path="$HOME/.config"
_panel_name_="$(cat ${_panel_name_path_})"
BLOBPATH="$home_config_path/blob"

if [ "$_panel_name_" = 'polybar' ]; then
	PANELPATH="${BLOBPATH}/polybar"
else
	PANELPATH="${BLOBPATH}/tint2"
fi	

path_to_style="${PANELPATH}/${style_name}"

if ! . "${theme_file_2_source}";then
	echo "[ERROR] $0: failed to source ${theme_file_2_source}"
fi

kitty_themeing(){
	blob_kitty_theme_path="${path_to_style}/config/kitty"
	echo "background_opacity 0.8" > "${blob_kitty_theme_path}/theme.conf"
	echo "# color scheme" >> "${blob_kitty_theme_path}/theme.conf"
	echo "include ./themes/${style_name}.conf" >> "${blob_kitty_theme_path}/theme.conf"
	tee "$blob_kitty_theme_path/themes/${style_name}.conf" <<- EOF >/dev/null 2>&1
	foreground            $color9
	background            $color1
	selection_foreground  $color13
	selection_background  $color5
	url_color             $color6
	cursor                $color8
	
	# black
	color0   $color1
	color8   $color2
	
	# red
	color1   $color11
	color9   $color11
	
	# green
	color2   $color8
	color10  $color8
	
	# yellow
	color3   $color12
	color11  $color12
	
	# blue
	color4   $color6
	color12  $color6
	
	# magenta
	color5   $color7
	color13  $color7
	
	# cyan
	color6   $color4
	color14  $color4
	
	# white
	color7   $color9
	color15  $color13
	EOF
}

openbox_themeing(){
	blob_openbox_theme_path="${path_to_style}/config/openbox/theme"
	tee "$blob_openbox_theme_path/rctheme" <<- EOF >/dev/null 2>&1
	bottom=10
	top=0
	right=10
	left=10
	font=JetBrainsMono
	size=9
	theme=$theme_name_from_gtk2
	titleLayout=MLC
	EOF
}

alacritty_themeing(){
	blob_alacritty_theme_path="${path_to_style}/config/alacritty"
	cd "$blob_alacritty_theme_path"
	tee "$home_alacritty_theme_path/colorschemes/${style_name}" <<- EOF >/dev/null 2>&1
	# Default colors
	[colors.primary]
	background = "$color1"
	foreground = "$color9"
	
	# Cursor colors
	[colors.cursor]
	text = "$color1"
	cursor = "$color8"
	
	# Normal colors
	[colors.normal]
	black = "$color2"
	red = "$color11"
	green = "$color8"
	yellow = "$color12"
	blue = "$color6"
	magenta = "$color7"
	cyan = "$color4"
	white = "$color9"
	
	# Bright colors
	[colors.bright]
	black = "$color3"
	red = "$color11"
	green = "$color8"
	yellow = "$color12"
	blue = "$color6"
	magenta = "$color7"
	cyan = "$color4"
	white = "$color13"
	EOF
	ln -sf "colorschemes/${style_name}" "colors.yml"
}

