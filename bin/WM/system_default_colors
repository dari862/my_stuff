#!/bin/bash
STYLEPATH="${1-}"
style="${2-}"

theme_file_name="${style_name}_2_source"
theme_file_2_source="/tmp/$USER/$theme_file_name"
theme_it=""

show_em(){
	echo "[ERROR] $0 : $1"
}

theme_color_it(){
	theme_it="$@"
	if [ ! -f "$theme_file_2_source" ];then
		/usr/share/my_stuff/bin/WM/system_default_colors_scripts/palette_creator "$theme_file_2_source"
	fi
	for app in ${theme_it};do
		/usr/share/my_stuff/bin/WM/system_default_colors_scripts/theme_color_creater "$app" "${style}" "${theme_file_2_source}" || show_em "failed to run system_default_colors $app"
	done
}

if command -v openbox >/dev/null 2>&1;then
	if [ ! -f "$STYLEPATH/openboxrctheme" ];then
		theme_it="$theme_it openbox"
	fi
fi

if [ ! -f "$STYLEPATH/config/dunst/theme.dunstrc" ];then
	theme_it="$theme_it dunst"
fi

if command -v jgmenu >/dev/null 2>&1;then
	if [ ! -f "$STYLEPATH/jgmenu_theme" ];then
		theme_it="$theme_it jgmenu"
	fi
fi

if command -v geany >/dev/null 2>&1;then
	if [ ! -f "$HOME/.config/geany/colorschemes/${style}.conf" ];then
		theme_it="$theme_it geany"
	fi
fi

if command -v kitty >/dev/null 2>&1;then
	if [ ! -f "$HOME/.config/kitty/themes/${style}.conf" ];then
		theme_it="$theme_it kitty"
	fi
fi

if command -v alacritty >/dev/null 2>&1;then
	if [ ! -f "$HOME/.config/alacritty/colorschemes/${style}.yml" ];then
		theme_it="$theme_it alacritty"
	fi
fi

if [ -n "$theme_it" ];then
	theme_color_it
fi
	
