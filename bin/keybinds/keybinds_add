#!/bin/sh
# need superuser : used by keybinds
# rxvt-unicode
# bspwm
set -e
__package_name="${1:-}"
__distro_path_lib="${2:-}"
current_script_path="${3:-}"
file_to_cat=""
keybinds_conf_path=".config/keybinds/keybinds.conf"

. "$__distro_path_lib"
. "${__distro_path_root}/lib/common/WM"

write2file=false

cd "$current_script_path"/skel

if [ "$__package_name" = "rxvt-unicode" ] || [ "$__package_name" = "rxvt" ];then
	file_to_cat="${file_to_cat} rxvt"
	write2file=true
elif [ "$__package_name" = "bspwm" ];then
	write2file=false
else
	for _p_ in *;do
		if [ "${__package_name}.conf" = "${_p_}" ];then
			file_to_cat="${file_to_cat} $_p_"
			write2file=true
			break
		fi
	done
fi

if [ "$write2file" = true ];then
	cat ${file_to_cat} | tee -a "${__distro_path_root}/system_files/skel/${keybinds_conf_path}" >/dev/null 2>&1
elif [ "$__package_name" = "bspwm" ];then
	sed -i ':a;N;$!ba;s/#;\n#; end of sxhkd/seded_end_of_sxhkd/g;/seded_end_of_sxhkd/ {
  		r sxhkd_bspwm
  		r sxhkd_z_end
  		n
		}' "${__distro_path_root}/system_files/skel/${keybinds_conf_path}"
fi

for d in /home/*/; do
	if [ -f "${d}${usr_flag_setup_path}" ];then
		# Create config folders if does not exists
		file_2_edit="${d}${keybinds_conf_path}"
		user_and_group=$(stat "$(dirname "$file_2_edit")" -c %u:%g)
		if [ "$__package_name" = "bspwm" ];then
			sed -i ':a;N;$!ba;s/#;\n#; end of sxhkd/seded_end_of_sxhkd/g;/seded_end_of_sxhkd/ {
  				r sxhkd_bspwm
  				r sxhkd_z_end
  				n
				}' "$file_2_edit"
		else
			cat ${file_to_cat} | tee -a "$file_2_edit" >/dev/null 2>&1
		fi
		chown -R "$user_and_group" "$file_2_edit"
	fi
done

MainDir="${__distro_path_root}/system_files/skel"

. "${current_script_path}/core/file_path_to_edit.conf"
. "${current_script_path}/core/lib"

mkdir -p "${temp_shortcuts_path}"

cp -r "$MainDir/.config/keybinds/keybinds.conf" "${temp_shortcuts_path}"
cp -r "${current_script_path}/core/keybinds_to_sourcemainbindkey.conf" "${temp_shortcuts_path}"

cd "${temp_shortcuts_path}"

build_sourcemainbindkey_conf_file
. "${temp_shortcuts_path}/sourcemainbindkey.conf"

case "$__package_name" in
	alacritty)		build_alacritty_tmp_file
	;;
	bspwm)			build_sxhkd_bspwm_file
					build_rofi_tmp_file "bspwm"					
	;;
	clipit)			sed_clipit
	;;
	geany)			sed_geanyrc
	;;
	lxterminal)		sed_lxterminal
	;;
	mpv)			build_mpv_tmp_file
	;;
	nsxiv)			sed_nsxiv
	;;
	thunar)			build_Thunar_tmp_file
	;;
	rxvt-unicode)	build_x11_tmp_file
	;;
	viewnior)		build_viewnior_tmp_file
	;;
	zathura)		build_zathura_tmp_file
	;;
esac
build_shortcut_read_file

finalize_it

. "${__distro_path_root}/lib/common/common"

for d in /home/*/; do
   if home_dir_has_user "$d";then
		:
	else
		continue	# Skip dirs that no are homes
	fi
	
	Picked_USER="${d#/home/}"
	Picked_USER="${Picked_USER%%/*}"
	MainDir="/home/$Picked_USER"
	
    user_and_group=$(stat "$(dirname "${MainDir}/.config")" -c %u:%g)
    say "Copying keybind files to user ${Picked_USER}."
    
	. "${current_script_path}/core/file_path_to_edit.conf"
	. "${current_script_path}/core/lib"
	
	finalize_it
    chown -R "$user_and_group" "$d"
done

clean_it_up
