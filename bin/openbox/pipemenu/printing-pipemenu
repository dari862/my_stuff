. "/usr/share/my_stuff/lib/common/includes_functions"

HELP='    bl-printing-pipemenu an Openbox Pipe Menu for configuring printing
    It should normally be called from an openbox menu.

Options (usually passed from the menu):
    -h --help   show this message
    --install   install printing support

    If bl-printing-pipemenu is called with no options (the usual method),
    it will output an xml openbox pipemenu
    for installing printing support and configuring printing.
'
# look for a help option somewhere
for i in "$@"
do
    case "$i" in
    -h|--help)
        echo "$HELP"
        exit 0
        ;;
    esac
done

if [ "${1-}" = "-e" ] || [ "${1-}" = "--enable" ];then
	popup_terminal "echo 'CUPS is installed but not running' && read -p 'Press enter to try to start CUPS' && service_manager start cups.service"
fi

# Pipemenu
menuStart
if dpkg-query -W cups > /dev/null 2>&1; then
	if type 'system-config-printer' > /dev/null 2>&1 ; then
		menuItem 'Configure Printers' 'system-config-printer'
	fi
	
	if service_manager is-active cups ; then
		menuItem 'open cups admin page' "my-www-browser http://localhost:631"
	else
		menuItem 'enable cups admin page' "$0 --enable"
	fi
else
	menuItem 'install Printers Drivers' 'popup_terminal --install cups'
fi
menuEnd
exit 0
