#!/bin/bash

run_tweeks_script_name="my-tweeks"

_TWEEKS_DIR="/usr/share/DmDmDmdMdMdM/bin/not_add_2_path/tweeks_center"

HELP='    my-tweeks-pipemenu a obmenu Pipe Menu for runing tweeks
    It should normally be called from a obmenu menu.

Options (usually passed from the menu):
    -h --help   show this message
    --openboxmenu   generate xml obmenu pipemenu for run tweeks.
    --jgmenu   generate jgmenu pipemenu for run tweeks.

'

########################################################################

# look for a help option somewhere
for i in "$@"
do
    case "$i" in
    -h|--help)
        echo "$HELP"
        exit 0
        ;;
    esac
done

. "/usr/share/DmDmDmdMdMdM/lib/common/includes_functions"

TWEEKS=($(ls ${_TWEEKS_DIR}))

if [[ ${1-} = --openboxmenu ]]; then # pipemenu
    shift 1
	menuStart "RunDebianTweeks" "Run Debian Tweeks"
	for tweek in "${TWEEKS[@]}"; do
    	[ "$(${run_tweeks_script_name} --check ${tweek})" != "enabled" ] && menuItem "run ${tweek}" "${run_tweeks_script_name} ${tweek}"
    done
    menuEnd
 #    menuEnd   
elif [[ ${1-} = --jgmenu ]]; then # pipemenu
    shift 1
	for tweek in "${TWEEKS[@]}"; do
    	[ "$(${run_tweeks_script_name} --check ${tweek})" != "enabled" ] && jgmenuItem "run ${tweek}" "${run_tweeks_script_name} ${tweek}"
    done
    jgmenuEnd
#    menuEnd
elif [[ ${1-} ]]; then
    echo "$0: no such option $*" >&2
    echo
    echo "#################################################"
    echo
    echo "$HELP"
    exit 1
fi
exit 0
