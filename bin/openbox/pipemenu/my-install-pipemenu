#!/bin/bash

installation_script_name="my-installer"
_SCRIPTS_LIBDIR="/usr/share/DmDmDmdMdMdM/bin/not_add_2_path/apps_center"
GAMING_SCRIPTS_LIBDIR="$_SCRIPTS_LIBDIR/Gaming"

HELP='    my-install-pipemenu a obmenu Pipe Menu for installing applications
    It should normally be called from a obmenu menu.

Options (usually passed from the menu):
    -h --help   show this message
    --openboxmenu   generate xml obmenu pipemenu for installing applications.
    --jgmenu   generate jgmenu pipemenu for installing applications.
    (the package must be in one of the app lists in this file)

'
LIST_OF_APPS_SCRIPTS_=($(ls -d "$_SCRIPTS_LIBDIR"/*/ 2>/dev/null | grep -v "GAMING_SCRIPTS_LIBDIR"))
LIST_OF_GAMES_SCRIPTS_=($(ls -d "$GAMING_SCRIPTS_LIBDIR"/*/ 2>/dev/null))
########################################################################

# look for a help option somewhere
for i in "$@"
do
    case "$i" in
    -h|--help)
        echo "$HELP"
        exit 0
        ;;
    esac
done

. "/usr/share/DmDmDmdMdMdM/lib/common/includes_functions"

if [[ ${1-} = --openboxmenu ]]; then # pipemenu
	# This function is specific to this script.
    # It generates an install submenu for a group of packages.
    # Usage: generate_installmenu tag label list (of packages)
    generate_installmenu() {
        local tag=$1
        local label=$2
        shift 2
        if [ "${#@}" -gt 0 ]; then
        	menuSubmenu "$tag" "$label"
        	for App in "${@}"; do
        		if [[ $App == script_* ]]; then
        			App=${App//script_/} 
        			hash "${App}" 2>/dev/null || menuItem "Install ${App}" "${installation_script_name} --script ${App}"
        		else
        			App_name=$(echo "${App}" | awk -F"_" '{print $1}')
                	hash "${App_name}" 2>/dev/null || menuItem "Install ${App}" "${installation_script_name} --install ${App}"
                fi
        	done
        	menuSubmenuEnd
        fi
    }
	menuStart "installfavouritepackages" "Install Favourite Packages"
	for d in "${LIST_OF_APPS_SCRIPTS_[@]}";do
		apps_dir_name=$(basename $d)
		apps_dir_id=$(echo "$apps_dir_name" | sed 's/_/ /')
		apps_in_dir=()
		cd $d
		for script in *;do
			apps_in_dir+=("$script")
		done
		generate_installmenu "$apps_dir_name" "$apps_dir_id" "${apps_in_dir[@]}"
	done
	if [ ! -f "/usr/share/DmDmDmdMdMdM/Gaming_ready" ];then
		if [ ! -f "/usr/share/DmDmDmdMdMdM/Gaming_Drivers_ready" ];then
			menuItem "GPU Driver (GamingEss after install)" "${installation_script_name} --install GPU_Driver_"
		else
			menuItem "Gaming Essential (GamingMenu after install)" "${installation_script_name} --install Gaming_Essential_"
		fi
	else
		menuSubmenu "GamingMenu" "Gaming"
			for gd in "${LIST_OF_GAMES_SCRIPTS_[@]}";do
				Gaming_dir_name=$(basename $gd)
				Gaming_dir_id=$(echo "$Gaming_dir_name" | sed 's/_/ /')
				Gaming_in_dir=()
				cd $gd
				for gscript in *;do
					Gaming_in_dir+=("$gscript")
				done
				generate_installmenu "$Gaming_dir_name" "$Gaming_dir_id" "${Gaming_in_dir[@]}"
			done
		menuSubmenuEnd
	fi
	if [ ! -f /etc/apt/sources.list.d/kali.list ] || [ ! -f /etc/apt/sources.list.d/parrot.list ] || [ ! -f /etc/apt/preferences.d/kali.pref ] || [ ! -f /etc/apt/preferences.d/parrot.pref ];then
		menuItem "Cybersecurity Apps" "${installation_script_name} --install Cyber_"
	fi
    menuEnd
 #    menuEnd   
elif [[ ${1-} = --jgmenu ]]; then # pipemenu
    # This function is specific to this script.
    # It generates an install submenu for a group of packages.
    # Usage: generate_installmenu tag label list (of packages)
    generate_installmenu_jgmenu() {
        local tag=$1
        local label=$2
        shift 2
        for App in "${@}"; do
       		if [[ $App == script_* ]]; then
        		App=${App//script_/} 
        		hash "${App}" 2>/dev/null || jgmenuItem "Install ${App}" "${installation_script_name} --script ${App}"
        	else
        		App_name=$(echo "${App}" | awk -F"_" '{print $1}')
                hash "${App_name}" 2>/dev/null || jgmenuItem "Install ${App}" "${installation_script_name} --install ${App}"
            fi
        done
        [[ -n ${menu_content[$tag]} ]] && jgmenuSubmenu 'root' "$tag" "$label"
    }
	for d in $_SCRIPTS_LIBDIR/*;do
			apps_dir_name=$(basename $d)
			apps_dir_id=$(echo "$apps_dir_name" | sed 's/_/ /')
			apps_in_dir=()
			cd $d
			for script in *;do
				apps_in_dir+=("$script")
			done
			generate_installmenu_jgmenu "$apps_dir_name" "$apps_dir_id" "${apps_in_dir[@]}"
	done
	if [ ! -f "/usr/share/DmDmDmdMdMdM/Gaming_ready" ];then
		jgmenuItem "GPU Driver (GamingMenu after install)" "${installation_script_name} --install GPU_Driver_"
	else
		jgmenuSubmenu 'root' "GamingMenu" "Gaming"
			for gd in $GAMING_SCRIPTS_LIBDIR/*;do
				Gaming_dir_name=$(basename $gd)
				Gaming_dir_id=$(echo "$Gaming_dir_name" | sed 's/_/ /')
				Gaming_in_dir=()
				cd $gd
				for gscript in *;do
					Gaming_in_dir+=("$gscript")
				done
				generate_installmenu_jgmenu "$Gaming_dir_name" "$Gaming_dir_id" "${Gaming_in_dir[@]}"
		done
	fi
	
	if [ ! -f /etc/apt/sources.list.d/kali.list ] || [ ! -f /etc/apt/sources.list.d/parrot.list ] || [ ! -f /etc/apt/preferences.d/kali.pref ] || [ ! -f /etc/apt/preferences.d/parrot.pref ];then
		jgmenuItem "Cybersecurity Apps" "${installation_script_name} --install Cyber_"
	fi
    jgmenuEnd
#    menuEnd
elif [[ ${1-} ]]; then
    echo "$0: no such option $*" >&2
    echo
    echo "#################################################"
    echo
    echo "$HELP"
    exit 1
fi
exit 0
