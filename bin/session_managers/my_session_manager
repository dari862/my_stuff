#!/bin/sh
## Commands Executed By Openbox Powermenu

## Rofi #############################################
. "/usr/share/my_stuff/lib/common/WM"
. "/usr/share/my_stuff/lib/common/rofi"

opt_="${1-}"
opt2_="${2-}"

confirm_it=false

_logout(){
	[ "$confirm_it" = true ] && confirmation_dialog
	wm_name="$(cat "$WM_name_file")"
	if [ "$wm_name" = "openbox" ];then
		openbox --exit
	elif [ "$wm_name" = "bspwm" ];then
		bspc quit
	elif [ "$wm_name" = "i3" ];then
		i3-msg exit
	elif [ "$wm_name" = "qtile" ];then
		qtile cmd-obj -o cmd -f shutdown
	elif [ "$wm_name" = "awesome" ];then
		awesome --replace
	else
		([ "$(command -v systemctl)" ] && systemctl --user exit) || loginctl terminate-session "$XDG_SESSION_ID"
	fi
} 

_reload(){
	wm_name="$(cat "$WM_name_file")"
	if [ "$wm_name" = "openbox" ];then
		openbox --reconfigure
	elif [ "$wm_name" = "bspwm" ];then
		bspc --restart
	elif [ "$wm_name" = "i3" ];then
		i3-msg restart
	elif [ "$wm_name" = "qtile" ];then
		qtile cmd-obj -o cmd -f restart
	elif [ "$wm_name" = "awesome" ];then
		awesome --replace
	fi
} 

_suspend(){
	[ "$confirm_it" = true ] && confirmation_dialog
	# The systemd or elogind compatibility magic.   #
	mpc -q pause 
	amixer set Master mute 
	extra_stuff suspend
}

extra_stuff(){
	[ "$confirm_it" = true ] && confirmation_dialog
	# hibernate | hybrid-sleep | suspend-then-hibernate | reboot | poweroff
	# The systemd or elogind compatibility magic.   #
	if command -v systemctl >/dev/null 2>&1;then
		systemctl "$1"
	else
		loginctl "$1"
	fi
	exit $?
}

_lock(){
	[ "$confirm_it" = true ] && confirmation_dialog
    my-locker || loginctl lock "$XDG_SESSION_ID"
    exit $?
}

_moniter_off(){
	xset dpms force off || ( xset s blank && xset s activate )
}

on_terminal(){
   	if [ -t 0 ]
   	then
       	if [ -t 1 ] && [ -t 2 ]
       	then
           	return 0
       	else
           	echo "$0: STDIN is on terminal, but not STDOUT or STDERR" >&2
           	exit 1
       	fi
   	else
       	return 1
   	fi
}

on_graphical_session(){
   	[ -n "$DISPLAY" ] || [ -n "$WAYLAND_DISPLAY" ] && return 0
   	return 1
}

tty_menu(){
	opt_=""
   	clear
   	printf "Please choose an option \n"
   	echo "1) Logout	  3) Hibernate	    5) Reboot	      7) Quit
2) Suspend	  4) Hybrid-Sleep   6) Power-Off"
	read option
	option="$(echo "${option}" | tr '[:upper:]' '[:lower:]' )"
    case $option in
    	"logout"|1)		opt_="logout";;
    	"suspend"|2)	opt_="suspent";;
    	"hibernate"|3)	opt_="hibernate";;
    	"hybrid"*|4)	opt_="hybrid-sleep";;
    	"reboot"|5)		opt_="reboot";;
    	"power"*|6)		opt_="shutdown";;
    	"quit"|7)		echo 'exit cancelled' && exit;;
    	*) 				exit 1 ;;
    esac
}

confirmation_dialog(){
	if [ "$layout" = "TRUE" ]; then
		yes=''
		no=''
	else
		yes=' Yes'
		no=' No'
	fi
	
	ans="$(printf "$yes\n$no" | rofi -dmenu -p 'Confirmation' -mesg 'Are you Sure?' -theme "$rofi_style_dir"/confirm.rasi)"
	
	if [ "$ans" = "$yes" ];then
		return
	else
		exit
	fi
}

rofi_menu(){
	opt_=""
	rofi_command="rofi -theme ${rofi_style_dir}/powermenu.rasi"
	
	uptime=$(uptime -p | sed -e 's/up //g')
	
	## Buttons
	if [ "$layout" = "TRUE" ]; then
		shutdown=""
		reboot=""
		lock=""
		suspend=""
		logout=""
	else
		shutdown=" Shutdown"
		reboot=" Restart"
		lock=" Lock"
		suspend=" Sleep"
		logout=" Logout"
	fi
	
	# Variable passed to rofi
	options="$lock\n$suspend\n$logout\n$reboot\n$shutdown"
	
	chosen="$(echo "$options" | $rofi_command -p "UP - $uptime" -dmenu -selected-row 0)"
	case "$chosen" in
    	"$shutdown")
			opt_="shutdown"
        	;;
    	"$reboot")
			opt_="reboot"
        	;;
    	"$lock")
        	opt_="lock"
        	;;
    	"$suspend")
			opt_="suspent"
        	;;
    	"$logout")
			opt_="logout"
        	;;
        *) exit 0;;
	esac
}

yad_menu(){
	opt_=""
	yad --class=WmanExit --title "Exit" --close-on-unfocus --undecorated --center --on-top --borders=10 --window-icon=system-log-out \
       		--button=" _Logout!system-log-out!Logout":10 \
       		--button=" L_ock Screen!system-lock-screen!":20 \
       		--button=" _Suspend!system-suspend!":30 \
       		--button=" Re_boot!system-reboot!":40 \
       		--button=" _Power Off!system-shutdown!":50
     case $? in
    	10) opt_="logout";;
     	20) opt_="lock";;
      	30) opt_="suspent";;
      	40) opt_="reboot";;
      	50) opt_="shutdown";;
      	*) exit 0;;
    esac
}

help_menu(){
	echo "
Powermenu
	
    	-h --help		Show 			this help
    	-k --lock		Lock 			screen	Does not work for a tty session
    	-l --logout		Logout			Also works for tty.
    	-s --suspend	Suspend			State determined by ACPI S0 S1 or S3
    	-i --hibernate	Suspend to Disk	Requires enough swap to store RAM
    	-y --hybrid		Hybrid Sleep	ACPI must support sleep state S3
    	-b --reboot	Reboot    	
    	-p --poweroff	Shut down
    	
    	text menu at a TTY
"
}
## Options #############################################
if [ "$opt_" = "--no-confirm" ] || [ "$opt_" = "-n" ] ;then
	opt_="${opt2_}"
else
	confirm_it=true
fi

if on_graphical_session;then
	if [ -z "$opt_" ];then
		show_menu="rofi"
	elif  [ "$opt_" = "--rofi" ]; then	
		show_menu="rofi"
	elif  [ "$opt_" = "--yad" ]; then		
		show_menu="yad"
	elif  [ "$opt_" = "--tty" ]; then		
		show_menu="tty"
	fi
elif on_terminal; then
	if  [ "$opt_" = "--tty" ] || [ -z "$opt_" ];then
		show_menu="tty"
	fi
else
	printf "$0 : failed to run on_graphical_session and on_terminal."
	exit 1
fi

if  [ "$show_menu" = "rofi" ]; then	
	layout="$(grep BUTTON "${rofi_style_dir}"/powermenu.rasi | cut -d'=' -f2 | tr -d '[:blank:],*/')"
	rofi_menu
elif  [ "$show_menu" = "yad" ]; then		
	yad_menu
elif  [ "$show_menu" = "tty" ]; then		
	tty_menu
fi

case "$opt_" in
	logout) _logout;;
	suspent) _suspend;;
	reboot) extra_stuff reboot;;
	shutdown) extra_stuff poweroff;;
	lock) _lock;;
	hibernate) extra_stuff hibernate;;
	hybrid-Sleep) extra_stuff hybrid-sleep;;
	moniter_off) _moniter_off ;;
	reload) _reload ;;
	*) help_menu;;
esac
