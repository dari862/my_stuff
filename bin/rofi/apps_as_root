. "/usr/share/DmDmDmdMdMdM/lib/common/rofi"

SCRIPT_DIR="$( cd -- "$( dirname -- "${BASH_SOURCE[0]:-$0}"; )" &> /dev/null && pwd 2> /dev/null; )";
app_2_run_as_root="$1"

rofi_askpass(){
	rofi -dmenu\
     	-password\
     	-i\
     	-no-fixed-num-lines\
     	-p "User Password: "\
     	-theme "$rofi_style_dir"/askpass.rasi
}

if [ -z "${app_2_run_as_root}" ];then
	rofi_command="rofi -theme $rofi_style_dir/runner.rasi"
	# Apps
	terminal=" Terminal"
	files=" File-Manager"
	editor=" Text-Editor"
	clifm=" Ranger"
	vim=" CLI Editor"
	# Variable passed to rofi
	options="$terminal\n$files\n$editor\n$clifm\n$vim"
	
	# Functions
	chosen="$(echo -e "$options" | $rofi_command -p "Run apps as root" -dmenu -selected-row 0)"
	case $chosen in
    	$terminal)
        	app_2_run_as_root="my-terminal-emulator"
			Extra_Arg=""
        	;;
    	$files)
        	app_2_run_as_root="my-file-manager"
			Extra_Arg=""
        	;;
    	$editor)
        	app_2_run_as_root="my-text-editor"
			Extra_Arg=""
        	;;
    	$clifm)
        	app_2_run_as_root="popup_terminal"
			Extra_Arg="-e ranger"
        	;;
    	$vim)
        	app_2_run_as_root="my-cli-editor"
        	Extra_Arg="sudo"
        	;;
	esac
else
	shift 1
	Extra_Arg="$@"
fi

app_2_run_as_root="$(which $app_2_run_as_root)"
command_2_run="${app_2_run_as_root} ${Extra_Arg}"

## rofi sudo askpass helper
export SUDO_ASKPASS="$(rofi_askpass)"
	
## execute the application
sudo -A ${command_2_run} 2>/dev/null
