#!/bin/sh
# if this line exist script will be part of hub script.
# Import Current Theme
. "/usr/share/my_stuff/lib/common/WM"
. "/usr/share/my_stuff/lib/common/rofi"

RASI="$rofi_style_dir/screenshot.rasi"

# Theme Elements
prompt='Screenshot'
mesg="Directory :: `xdg-user-dir PICTURES`/Screenshots"

# Options
layout="$(cat ${RASI} | grep 'USE_ICON' | cut -d'=' -f2)"
if [ "$layout" = 'NO' ]; then
	shot_now="Ó¶¢ Capture Desktop"
	shot_area="Ó•í Capture Area"
	shot_win="Ó¶à Capture Window"
	shot_after_5sec="Ó®ç Capture in 5s"
	shot_after_10sec="Ó§π Capture in 10s"
else
	shot_now="Ó¶¢"
	shot_area="Ó•í"
	shot_win="Ó¶à"
	shot_after_5sec="Ó®ç"
	shot_after_10sec="Ó§π"
fi

# Rofi CMD
rofi_cmd() {
	rofi -dmenu \
		-p "$prompt" \
		-mesg "$mesg" \
		-markup-rows \
		-theme ${RASI}
}

# Pass variables to rofi dmenu
run_rofi() {
	printf "$shot_now\n$shot_area\n$shot_win\n$shot_after_5sec\n$shot_after_10sec" | rofi_cmd
}

# Actions
chosen="$(run_rofi)"
case ${chosen} in
    $shot_now)
		ac-shots
        ;;
    $shot_area)
		ac-shots --area
        ;;
    $shot_win)
		ac-shots --win
        ;;
    $shot_after_5sec)
		ac-shots --delay 5
        ;;
    $shot_after_10sec)
		ac-shots --delay 10
        ;;
esac
