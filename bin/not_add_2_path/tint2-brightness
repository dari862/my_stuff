#!/usr/bin/env bash

# Graphics card

screens="$(xrandr -q | grep -v "HDMI" | grep " connected")"

[ -z "$screen" ] && exit 0

CARD=$(ls /sys/class/backlight | head -n 1)

if [[ -z "$CARD" ]]; then
	exit 1
fi

#####################################################################################
# software to use
Software_to_use_for_Brightness="light"

if [[ "$CARD" == *"intel_"* ]]; then
	# Get brightness
	get_backlight() {
		BNESS=$(xbacklight -get)
		LIGHT=${BNESS%.*}
		echo "${LIGHT}%"
	}
	
	# Increase brightness
	inc_backlight() {
		xbacklight -inc 10 && get_icon && dunstify -u low --replace=69 -i "$icon" "Brightness : $(get_backlight)"
	}
	
	# Decrease brightness
	dec_backlight() {
		xbacklight -dec 10 && get_icon && dunstify -u low --replace=69 -i "$icon" "Brightness : $(get_backlight)"
	}
elif command -v pnmixer &> /dev/null; then
	get_backlight() {
		LIGHT=$(printf "%.0f\n" `light -G`)
		echo "${LIGHT}%"
	}
	
	# Increase brightness
	inc_backlight() {
		light -A 5 && get_icon && dunstify -u low --replace=69 -i "$icon" "Brightness : $(get_backlight)"
	}
	
	# Decrease brightness
	dec_backlight() {
		light -U 5 && get_icon && dunstify -u low --replace=69 -i "$icon" "Brightness : $(get_backlight)"
	}
fi

# Get icons
get_icon() {
	backlight="$(get_backlight)"
	current="${backlight%%%}"
	if [[ ("$current" -ge "0") && ("$current" -le "25") ]]; then
		icon=''
	elif [[ ("$current" -ge "25") && ("$current" -le "50") ]]; then
		icon=''
	elif [[ ("$current" -ge "50") && ("$current" -le "75") ]]; then
		icon=''
	elif [[ ("$current" -ge "75") && ("$current" -le "100") ]]; then
		icon=''
	fi
}

#####################################################################################
# Get status
get_status() {
	get_icon
	echo "$icon $(get_backlight)"
}

# Execute accordingly
if [[ "$1" == "--get" ]]; then
	get_status
elif [[ "$1" == "--inc" ]]; then
	inc_backlight
elif [[ "$1" == "--dec" ]]; then
	dec_backlight
else
	get_status
fi
