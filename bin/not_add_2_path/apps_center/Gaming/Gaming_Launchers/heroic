#!/bin/sh

app_name="heroic"
if [ -f '/usr/share/my_stuff/system_files/Distrobox_ready' ];then
	app_name="heroic-games-launcher-bin"
	say 'Updating sources...' 1
	Distrobox_Package_update_
	
	clear
	say 'Installing package...' 1
	Distrobox_package_installer_ ${app_name} || continue
	
else
	say 'Updating sources...' 1
	Package_update_
	
	clear
	
	say 'Installing package...' 1
	
	cd "$(mktemp -d)" && wget -qO- 'https://api.github.com/repos/Heroic-Games-Launcher/HeroicGamesLauncher/releases/latest' \
  	| grep '"browser_download_url"' \
  	| grep '.deb' \
  	| cut -f2,3 -d':' \
  	| tr -d '"' \
  	| head -1 \
  	| xargs wget -i -
	my-superuser apt-get install -y ./heroic_*.deb
fi
