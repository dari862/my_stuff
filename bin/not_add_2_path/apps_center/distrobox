#!/bin/bash

app_name=$(basename $0)
extra_apps_=(podman)

skip_test="{1-}"

if hash distrobox 2>/dev/null && ! dpkg -s distrobox &>/dev/null;then
	sudo touch '/usr/share/DmDmDmdMdMdM/Distrobox_ready'
	exit
fi

failed_to_run(){
	__massage_="${1-}"
	echo "$__massage_"
	exit 1
}
###################################################################

. "/usr/share/DmDmDmdMdMdM/lib/common/Package-manager"
clear
say
say "INSTALL ${app_name}."
say '------------------------'
say "This script will install ${app_name}."
say
if [[ -z "${skip_test}" ]];then
	clear
	connectiontest 1 || failed_to_run "failed to install no internet."
	
	clear
	say 'Updating sources...' 1
	Package_update_ || failed_to_run "failed to update repo."
	
	clear
fi

say 'Installing package...' 1
Package_installer_ ${app_name} || failed_to_run "failed to install ${app_name}"

if [[ -n "${extra_apps_[*]}" ]];then
	say 'Installing extra packages...' 1
	Package_installer_ "${extra_apps_[@]}" || failed_to_run "failed to install ${extra_apps_[@]}"
	clear
fi

sudo ln -sf /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/DistroGUI/distrogui.desktop /usr/share/applications
sudo ln -sf /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/DistroGUI/distrogui /usr/share/DmDmDmdMdMdM/bin/apps

sudo touch '/usr/share/DmDmDmdMdMdM/Distrobox_ready'

say
say "${app_name} has been installed successfully."
say


