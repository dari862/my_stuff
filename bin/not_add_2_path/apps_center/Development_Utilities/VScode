#!/bin/bash
# Install Visual Studio Code and add repositories
app_name=$(code)
extra_apps_=()
apt_pref_file="vscode.pref"
###################################################################

. "/usr/share/DmDmDmdMdMdM/lib/common/Package-manager"

while true; do # do it until the package is successfully installed or user wants to exit
	if [[ $TRYAGAIN ]]; then # previous try failed
		say
		say "There was a problem installing ${app_name}."
		say
		prompt '  Hit any key to try again, or "q" to quit...' Q && break
	fi
	TRYAGAIN=true
	
	clear
	say
	say "INSTALL ${app_name}."
	say '------------------------'
	say "This script will install ${app_name}."
	say
	prompt '  Run the installer now?' || break
	
	clear
	connectiontest 1 || continue
	
	clear
	say "Configuring repositories..."
	wget -qO - "https://packages.microsoft.com/keys/microsoft.asc" | sudo gpg --dearmor --yes -o /usr/share/keyrings/vscode-keyring.gpg
	echo "deb [arch=amd64 signed-by=/usr/share/keyrings/vscode-keyring.gpg] http://packages.microsoft.com/repos/vscode stable main" | sudo tee /etc/apt/sources.list.d/vscode.list	
	echo 'Package: *' | sudo tee /etc/apt/preferences.d/${apt_pref_file}; echo 'Pin: origin packages.microsoft.com' | sudo tee -a /etc/apt/preferences.d/${apt_pref_file}; echo 'Pin-Priority: 100' | sudo tee -a /etc/apt/preferences.d/${apt_pref_file}

	say 'Updating sources...' 1
	Package_update_
	
	clear
	
	say 'Installing package...' 1

	Package_installer_ ${app_name} || continue
	
	if [[ -n "${extra_apps_[*]}" ]];then
		say 'Installing extra packages...' 1
		sudo apt install -t packages.microsoft.com -y "${extra_apps_[@]}" || continue
		clear
	fi
	say
	say "${app_name} has been installed successfully."
	say
	say 'Hit any key to exit...'
	read -srn1
	break
done

