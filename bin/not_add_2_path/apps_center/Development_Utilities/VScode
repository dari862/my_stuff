#!/bin/bash
# Install Visual Studio Code and add repositories

needed_app="${1-}"
app_name=(code)
extra_apps_=()
###################################################################

. "/usr/share/my_stuff/system_files/Package-manager"

while true; do # do it until the package is successfully installed or user wants to exit
	if [[ $TRYAGAIN ]]; then # previous try failed
		say
		say "There was a problem installing ${app_name}."
		say
		prompt '  Hit any key to try again, or "q" to quit...' Q && break
	fi
	TRYAGAIN=true
	
	clear
	say
	say "INSTALL ${app_name}."
	say '------------------------'
	say "This script will install ${app_name}."
	say
	if [[ -z "${needed_app}" ]];then
		prompt '  Run the installer now?' || break
	fi
	
	clear
	connectiontest 1 || continue
	
	clear
	say "Configuring repositories..."
	wget -qO - "https://packages.microsoft.com/keys/microsoft.asc" | sudo gpg --dearmor --yes -o /usr/share/keyrings/vscode-keyring.gpg
	echo "deb [arch=amd64 signed-by=/usr/share/keyrings/vscode-keyring.gpg] http://packages.microsoft.com/repos/vscode stable main" | sudo tee /etc/apt/sources.list.d/vscode.list > /dev/null 2>&1
	
	say 'Updating sources...' 1
	Package_update_
	
	clear
	
	say 'Installing package...' 1

	Package_installer_ ${app_name} || continue
	
	if [[ -n "${extra_apps_[*]}" ]];then
		say 'Installing extra packages...' 1
		Package_installer_ "${extra_apps_[@]}" || continue
		clear
	fi
	sudo cp -r /usr/share/my_stuff/lib/Dev-Env/Code /usr/share/my_stuff/system_files/skel/.config
	
	for d in /home/*/; do
    	[ "$(dirname "$d")" = "/home" ] && ! id "$(basename "$d")" &>/dev/null && continue	# Skip dirs that no are homes 
    	user_and_group=$(stat "$(dirname "$d/.config")" -c %u:%g)
    	if [[ ! -d "$d/.config" ]];then
			sudo cp -rv /usr/share/my_stuff/system_files/skel/.config/Code "$d/.config"
			sudo chown -R $user_and_group "$d/.config/Code"
		fi
	done
	
	remove_from_db
	
	say
	say "${app_name} has been installed successfully."
	say
	[[ -z "${needed_app}" ]] && say 'Hit any key to exit...'
	[[ -z "${needed_app}" ]] && read -srn1
	break
done

