#!/bin/bash
# Install emacs and add Doom Emacs distro

needed_app="${1-}"
app_name=(emacs)
Title="Doom Emacs"
extra_apps_=(emacs-gtk ripgrep)
###################################################################

. "/usr/share/my_stuff/system_files/Package-manager"
first_boot=false

while true; do # do it until the package is successfully installed or user wants to exit
	if [[ $TRYAGAIN ]]; then # previous try failed
		say
		say "There was a problem installing ${Title}."
		say
		prompt '  Hit any key to try again, or "q" to quit...' Q && break
	fi
	TRYAGAIN=true
	
	clear
	say
	say "INSTALL ${Title}."
	say '------------------------'
	say "This script will install ${Title}."
	say
	if [[ -z "${needed_app}" ]];then
		prompt '  Run the installer now?' || break
	fi
	
	clear
	connectiontest 1 || continue
	
	clear

	say 'Updating sources...' 1
	Package_update_
	
	clear
	
	say 'Installing package...' 1

	Package_installer_ ${app_name} || continue
	
	if [[ -n "${extra_apps_[*]}" ]];then
		say 'Installing extra packages...' 1
		Package_installer_ "${extra_apps_[@]}" || continue
		clear
	fi

	[[ -d "/usr/share/my_stuff/system_files/skel/.emacs.d" ]] && sudo rm -rdf /usr/share/my_stuff/system_files/skel/.emacs.d
	
	sudo git clone --depth 1 https://github.com/hlissner/doom-emacs /usr/share/my_stuff/system_files/skel/.emacs.d
	if ! grep -r 'export PATH=$PATH:$HOME/.emacs.d/bin'  "/usr/share/my_stuff/system_files/skel/.config/myshell" &>/dev/null;then
		echo "export PATH=$PATH:$HOME/.emacs.d/bin" | sudo tee -a "/usr/share/my_stuff/system_files/skel/.config/myshell/bash/profile" > /dev/null 2>&1
		echo "export PATH=$PATH:$HOME/.emacs.d/bin" | sudo tee -a "/usr/share/my_stuff/system_files/skel/.config/myshell/zsh/zprofile" > /dev/null 2>&1
	fi
	
	for d in /home/*/; do
    	[ "$(dirname "$d")" = "/home" ] && ! id "$(basename "$d")" &>/dev/null && continue	# Skip dirs that no are homes
    	user_and_group=$(stat "$(dirname "$d/.config")" -c %u:%g) 
    	[[ -d "$d/.emacs.d" ]] && sudo rm -rdf "$d/.emacs.d"
		sudo cp -rv /usr/share/my_stuff/system_files/skel/.emacs.d "$d/"
		sudo chown -R $user_and_group "$d/"
		echo "export PATH=$PATH:$HOME/.emacs.d/bin" | sudo tee -a "$d/.config/myshell/bash/profile" > /dev/null 2>&1
		echo "export PATH=$PATH:$HOME/.emacs.d/bin" | sudo tee -a "$d/.config/myshell/zsh/zprofile" > /dev/null 2>&1
	done
	
	remove_from_db
	
	first_boot=true
	
	say
	say "${Title} has been installed successfully."
	say
	[[ -z "${needed_app}" ]] && say "Hit any key to start ${Title} first boot..."
	[[ -z "${needed_app}" ]] && read -srn1
	break
done

if [ "${first_boot}" = "true" ];then
	export PATH=$PATH:$HOME/.emacs.d/bin
	doom install
fi
