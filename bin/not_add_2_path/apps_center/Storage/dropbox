#!/bin/bash

needed_app="${1-}"
app_name=$(basename $0)
extra_apps_=()

###################################################################

. "/usr/share/my_stuff/system_files/Package-manager"

while true; do # do it until the package is successfully installed or user wants to exit
	if [[ $TRYAGAIN ]]; then # previous try failed
		say
		say "There was a problem installing ${app_name}."
		say
		prompt '  Hit any key to try again, or "q" to quit...' Q && break
	fi
	TRYAGAIN=true
	
	clear
	say
	say "INSTALL ${app_name}."
	say '------------------------'
	say "This script will install ${app_name}."
	say
	if [[ -z "${needed_app}" ]];then
		prompt '  Run the installer now?' || break
	fi
	
	clear
	connectiontest 1 || continue
	
	clear
	say 'Updating sources...' 1
	Package_update_

	clear

	say 'Installing package...' 1
	Package_installer_ python3-gpg || Package_installer_ python3-gpgme
	
	if [[ ! -f "/usr/share/my_stuff/system_files/downloaded/dropbox/dropbox.py" ]];then
		sudo ls -nf /usr/share/my_stuff/bin/not_add_2_path/dropbox/dropbox.desktop /usr/share/applications/dropbox.desktop
		sudo ls -nf /usr/share/my_stuff/bin/not_add_2_path/dropbox/dropbox.1.gz /usr/share/man/man1/dropbox.1.gz2
		
		sudo mkdir -p /usr/share/my_stuff/system_files/downloaded/dropbox
		cd /usr/share/my_stuff/system_files/downloaded/dropbox
		sudo wget https://linux.dropboxstatic.com/packages/dropbox.py
		sudo chmod +x dropbox.py
		sudo ls -nf /usr/share/my_stuff/system_files/downloaded/dropbox/dropbox.py /usr/share/my_stuff/system_files/bin/dropbox
		echo '#!/bin/sh' > /tmp/dropbox_updater
		echo 'nohup dropbox update &>/dev/null' >> /tmp/dropbox_updater
		
		sudo mv "/tmp/dropbox_updater" "/usr/share/my_stuff/system_files/downloaded/dropbox/dropbox_updater"
		sudo chown root:root "/usr/share/my_stuff/system_files/downloaded/dropbox/dropbox_updater"
		sudo chmod +x "/usr/share/my_stuff/system_files/downloaded/dropbox/dropbox_updater"
		sudo ls -nf /usr/share/my_stuff/system_files/downloaded/dropbox/dropbox_updater /usr/share/my_stuff/system_files/updater/dropbox
		/usr/share/my_stuff/system_files/updater/dropbox
	else
		sudo ls -nf /usr/share/my_stuff/bin/not_add_2_path/dropbox/dropbox.desktop /usr/share/applications/dropbox.desktop
		sudo ls -nf /usr/share/my_stuff/bin/not_add_2_path/dropbox/dropbox.1.gz /usr/share/man/man1/dropbox.1.gz2
		sudo ls -nf /usr/share/my_stuff/system_files/downloaded/dropbox/dropbox.py /usr/share/my_stuff/system_files/bin/dropbox
		sudo ls -nf /usr/share/my_stuff/system_files/downloaded/dropbox/dropbox_updater /usr/share/my_stuff/system_files/updater/dropbox
	fi		
	
	remove_from_db
	
	say
	say "${app_name} has been installed successfully."
	say
	[[ -z "${needed_app}" ]] && say 'Hit any key to exit...'
	[[ -z "${needed_app}" ]] && read -srn1
	break
done

