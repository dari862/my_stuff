#!/bin/bash
app_name="Gaming Essential"
if [ -f /etc/os-release ]; then
    # freedesktop.org and systemd
    . /etc/os-release
    version_=$(echo "${VERSION_ID//./}")
    distro_name_="$ID"
    distro_name_and_ver_="${ID}_${version_}"
    version_codename="${VERSION_CODENAME}"
elif [ -f /etc/lsb-release ]; then
    # For some versions of Debian/Ubuntu without lsb_release command
    . /etc/lsb-release
    distro_name_="$DISTRIB_ID"
    distro_name_and_ver_="${DISTRIB_ID}_${DISTRIB_RELEASE}"
else
    # Fall back to uname, e.g. "Linux <version>", also works for BSD, etc.
    distro_name_="$(uname -s)"
    distro_name_and_ver_="$(uname -s)_$(uname -r)"
fi

SHELL_EXT="$(which gnome-shell &>/dev/null && echo gnome-shell-extension-gamemode)"

###################################################################

. "/usr/share/DmDmDmdMdMdM/lib/common/Package-manager"

keep_Sudo_refresed()
{
	while [ 1 ]
		do
			sudo -v
			sleep 10m
		done
}

while true; do # do it until the package is successfully installed or user wants to exit
	if [[ $TRYAGAIN ]]; then # previous try failed
		say
		say "There was a problem make your linux ${app_name}."
		say
		prompt '  Hit any key to try again, or "q" to quit...' Q && break
	fi
	TRYAGAIN=true
	
	clear
	say
	say "Linux ${app_name}."
	say '------------------------'
	say "This script will make your linux ${app_name}."
	say
	prompt '  Run the installer now?' || break
	
	keep_Sudo_refresed &
	
	clear
	say 'Updating sources...' 1
	Package_update_
	
	clear
	say 'add new repo ...' 1
	if ! $(dpkg --list 'lutris' 2>/dev/null);then
		echo "deb [signed-by=/usr/share/keyrings/lutris.gpg] https://download.opensuse.org/repositories/home:/strycore/$distro_name_and_ver_/ ./" | sudo tee /etc/apt/sources.list.d/lutris.list
		wget -q https://download.opensuse.org/repositories/home:/strycore/$distro_name_and_ver_/Release.key -O- | sudo gpg --dearmor | sudo tee /usr/share/keyrings/lutris.gpg > /dev/null 2>&1
		apt_pref_file="lutris.pref"
		echo 'Package: *' | sudo tee /etc/apt/preferences.d/${apt_pref_file}; echo 'Pin: origin download.opensuse.org' | sudo tee -a /etc/apt/preferences.d/${apt_pref_file}; echo 'Pin-Priority: 100' | sudo tee -a /etc/apt/preferences.d/${apt_pref_file}
	fi
	
	if ! $(dpkg --list 'winehq-staging' 2>/dev/null);then
		sudo mkdir -pm755 /etc/apt/keyrings
		sudo wget -O /etc/apt/keyrings/winehq-archive.key https://dl.winehq.org/wine-builds/winehq.key
		sudo wget -NP /etc/apt/sources.list.d/ https://dl.winehq.org/wine-builds/debian/dists/${version_codename}/winehq-${version_codename}.sources
		apt_pref_file="winehq-${version_codename}.pref"
		echo 'Package: *' | sudo tee /etc/apt/preferences.d/${apt_pref_file}; echo 'Pin: origin dl.winehq.org' | sudo tee -a /etc/apt/preferences.d/${apt_pref_file}; echo 'Pin-Priority: 100' | sudo tee -a /etc/apt/preferences.d/${apt_pref_file}
	fi
	
	sudo dpkg --add-architecture i386
	
	clear
	say 'Updating new sources...' 1
	Package_update_
	
	Package_installer_ libcec6
	Package_installer_ xboxdrv
	Package_installer_ mangohud goverlay gamemode $SHELL_EXT lutris || continue
	sudo apt-get install -t download.opensuse.org -y lutris || continue                  
	sudo apt-get install -t dl.winehq.org -y --install-recommends winehq-staging
	Package_installer_ wine wine64 wine-binfmt winetricks
	
	if [[ "$distro_name_" = "debian" ]];then
		Package_installer_ libavcodec59 steam-installer mesa-vulkan-drivers libglx-mesa0:i386 mesa-vulkan-drivers:i386 libgl1-mesa-dri:i386 libgtk2.0-0:i386 dnsmasq resolvconf
		sudo service dnsmasq restart
		sudo service resolvconf restart
		sudo mkdir -p "/usr/share/DmDmDmdMdMdM/skel/Desktop"
		sudo ln -s /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/apps_center/Steam_fix /usr/share/DmDmDmdMdMdM/skel/Desktop
		for d in /home/*/ ; do
    		[ "$(dirname "$d")" = "/home" ] && ! id "$(basename "$d")" &>/dev/null && continue	# Skip dirs that no are homes
		
			# Create config folders if no exists
			d="$d/Desktop/";  [ ! -d "$d" ] && sudo mkdir -v "$d" && sudo chown -R $(stat "$(dirname "$d")" -c %u:%g) "$d"
		
			sudo sudo ln -sf "/usr/share/DmDmDmdMdMdM/bin/not_add_2_path/apps_center/Steam_fix" "$d" && sudo chown $(stat "$(dirname "$d")" -c %u:%g) "$d"/Steam_fix
		done
	elif [[ "$distro_name_" = "ubuntu" ]];then
		Package_installer_ steam || continue
	fi
	
	Package_installer_ flatpak
	sudo flatpak remote-add --system --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
	sudo flatpak install -y --noninteractive net.davidotek.pupgui2 com.usebottles.bottles
	sudo flatpak install flathub com.github.tchx84.Flatseal
	
	say "Creating Check File (Gaming_ready)"
	sudo rm -rf /usr/share/DmDmDmdMdMdM/Gaming_Drivers_ready
	sudo touch /usr/share/DmDmDmdMdMdM/Gaming_ready
	
	say
	say " your linux  is ${app_name}."
	say
	say 'Hit any key to exit...'
	read -srn1
	
	break
done

