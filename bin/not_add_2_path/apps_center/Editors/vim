#!/bin/bash

app_name=$(basename $0)
extra_apps_=(nodejs)

###################################################################
Disto_path="/usr/share/my_stuff"
RC_FILE_Path="${Disto_path}/lib/apps/vim"
CONF_FILE_NAME="vimrc"

. "/usr/share/my_stuff/system_files/Package-manager"

while true; do # do it until the package is successfully installed or user wants to exit
	if [[ $TRYAGAIN ]]; then # previous try failed
		say
		say "There was a problem installing ${app_name}."
		say
		prompt '  Hit any key to try again, or "q" to quit...' Q && break
	fi
	TRYAGAIN=true
	
	clear
	say
	say "INSTALL ${app_name}."
	say '------------------------'
	say "This script will install ${app_name}."
	say
	prompt '  Run the installer now?' || break
	
	clear
	connectiontest 1 || continue
	
	clear
	say 'Updating sources...' 1
	Package_update_
	
	clear
	
	say 'Installing package...' 1

	Package_installer_ ${app_name} || continue
	say "Installing vim plugins for all users in /etc/vim/ ..."
	
	if [[ -n "${extra_apps_[*]}" ]];then
		say 'Installing extra packages...' 1
		Package_installer_ "${extra_apps_[@]}" || continue
		clear
	fi
	
	say "Adding plugins support to vim ..."
	sudo mkdir -vp "/etc/vim/autoload"
	sudo curl -fLo /etc/vim/autoload/plug.vim https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
	sudo mkdir -p "/etc/vim/plugged/"
	
	say "Adding plugins to /etc/vim/rc.local ..."
	if [ -s "/etc/vim/${CONF_FILE_NAME}.local" ]; then
		cat "${RC_FILE_Path}/${CONF_FILE_NAME}.local" /etc/vim/${CONF_FILE_NAME}.local | sudo tee /etc/vim/${CONF_FILE_NAME}.local > /dev/null 2>&1
	else
		sudo cp -v "${RC_FILE_Path}/${CONF_FILE_NAME}.local" /etc/vim/
	fi
	sudo vim +'PlugInstall --sync' +qa 		# Download all plugins non-interactively
	
	
	# Copy users config
	say "Setting configs to all users..."
	for d in /home/*/ /root/; do
    	[ "$(dirname "$d")" = "/home" ] && ! id "$(basename "$d")" &>/dev/null && continue	# Skip dirs that no are homes 
    	user_and_group=$(stat "$(dirname "$d/.config")" -c %u:%g)
    	if [[ -d "$d/.config/myshell" ]];then
			sudo cp -v "${RC_FILE_Path}/${CONF_FILE_NAME}" "$d/.${CONF_FILE_NAME}" && sudo chown -R $user_and_group "$d/.${CONF_FILE_NAME}"
			sudo sed -i 's/export VISUAL=.*/export VISUAL=vim/g' "$d/.config/myshell/zsh/zprofile"
			sudo sed -i 's/export CLI_EDITER=.*/export CLI_EDITER=vim/g' "$d/.config/myshell/zsh/zprofile"
			sudo sed -i 's/export VISUAL=.*/export VISUAL=vim/g' "$d/.config/myshell/bash/profile"
			sudo sed -i 's/export CLI_EDITER=.*/export CLI_EDITER=vim/g' "$d/.config/myshell/bash/profile"
			sudo chown -R $user_and_group "$d/.config/myshell/zsh/zprofile"
			sudo chown -R $user_and_group "$d/.config/myshell/bash/profile"
		fi
	done
	
	sudo cp -r "${RC_FILE_Path}/${CONF_FILE_NAME}" "${Disto_path}/system_files/skel/.${CONF_FILE_NAME}"
	
	sudo sed -i 's/export VISUAL=.*/export VISUAL=vim/g' "${Disto_path}/system_files/skel/.config/myshell/zsh/zprofile"
	sudo sed -i 's/export CLI_EDITER=.*/export CLI_EDITER=vim/g' "${Disto_path}/system_files/skel/.config/myshell/zsh/zprofile"
	sudo sed -i 's/export VISUAL=.*/export VISUAL=vim/g' "${Disto_path}/system_files/skel/.config/myshell/bash/profile"
	sudo sed -i 's/export CLI_EDITER=.*/export CLI_EDITER=vim/g' "${Disto_path}/system_files/skel/.config/myshell/bash/profile"
	
	remove_from_db
	
	say
	say "${app_name} has been installed successfully."
	say
	say 'Hit any key to exit...'
	read -srn1
	break
done

