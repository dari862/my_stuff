#!/bin/sh

app_name="geany"
say 'Installing geany...' 1
Package_installer_ ${app_name} || continue
copy_from_extra_skel ".config/geany" || continue

cd "/usr/share/my_suff/extra_blob/"
cd polybar
for theme in *;do
	my-superuser cp -r "${theme}/config/geany" "/usr/share/my_suff/system_files/blob/tint2/${theme}/config" 
done
