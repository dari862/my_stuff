#!/bin/sh

app_name="timeshift"
say 'Installing package...' 1

Package_installer_ ${app_name} || continue

if [[ -n "${extra_apps_[*]}" ]];then
	say 'Installing extra packages...' 1
	Package_installer_ "${extra_apps_[@]}" || continue
	clear
fi

say 'extra config...' 1
my-superuser mkdir -p /etc/apt/apt.conf.d/
my-superuser mv "/usr/share/my_stuff/bin/not_add_2_path/timeshift-autosnap-apt/80-timeshift-autosnap-apt" "/etc/apt/apt.conf.d/"
my-superuser mv "/usr/share/my_stuff/bin/not_add_2_path/timeshift-autosnap-apt/timeshift-autosnap-apt" "/usr/bin/"
my-superuser mv "/usr/share/my_stuff/bin/not_add_2_path/timeshift-autosnap-apt/timeshift-autosnap-apt" "/etc/"
