#!/bin/bash

app_name=$(basename $0)
extra_apps_=()

###################################################################

. "/usr/share/DmDmDmdMdMdM/lib/common/Package-manager"

while true; do # do it until the package is successfully installed or user wants to exit
	if [[ $TRYAGAIN ]]; then # previous try failed
		say
		say "There was a problem installing ${app_name}."
		say
		prompt '  Hit any key to try again, or "q" to quit...' Q && break
	fi
	TRYAGAIN=true
	
	clear
	say
	say "INSTALL ${app_name}."
	say '------------------------'
	say "This script will install ${app_name}."
	say
	prompt '  Run the installer now?' || break
	
	clear
	connectiontest 1 || continue
	
	clear
	say 'Updating sources...' 1
	Package_update_
	
	clear

	say 'Installing package...' 1

	Package_installer_ ${app_name} || continue
	
	if [[ -n "${extra_apps_[*]}" ]];then
		say 'Installing extra packages...' 1
		Package_installer_ "${extra_apps_[@]}" || continue
		clear
	fi
	
	if command -v jq &>/dev/null;then
		_lat_lon="$(curl -s "https://location.services.mozilla.com/v1/geolocate?key=geoclue" | jq -r '"\(.location.lat):\(.location.lng)"')"
	elif command -v awk &>/dev/null;then
		_lat_lon="$(curl -s "https://location.services.mozilla.com/v1/geolocate?key=geoclue" | awk 'OFS=":" {print $3,$5}' | tr -d ',}')"
	fi
	_lat="$(echo ${_lat_lon} | awk -F: '{print $1}')"
	_lon="$(echo ${_lat_lon} | awk -F: '{print $2}')"
	sudo sed -i "s/lat=*/lat=${_lat}/g" /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/color_temperature_adjuster_gui/color_temperature_adjuster.conf
	sudo sed -i "s/lon=*/lon=${_lon}/g" /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/color_temperature_adjuster_gui/color_temperature_adjuster.conf
	sudo mkdir -p /usr/share/DmDmDmdMdMdM/skel/.config/redshift
	sudo cp -r /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/color_temperature_adjuster_gui/color_temperature_adjuster.conf /usr/share/DmDmDmdMdMdM/skel/.config/redshift/redshift.conf
	
	sudo ln -sf /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/color_temperature_adjuster_gui/color_temperature_adjuster_gui /usr/share/DmDmDmdMdMdM/bin/apps
	sudo ln -sf /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/color_temperature_adjuster_gui/tray_color_temperature_adjuster /usr/share/DmDmDmdMdMdM/bin/apps
	sudo ln -sf /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/color_temperature_adjuster_gui/tray_redshift.desktop /usr/share/DmDmDmdMdMdM/skel/.config/autostart/
	
	sudo ln -sf /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/color_temperature_adjuster_gui/redshift.service /lib/systemd/user
	
	for d in /etc/skel/  /home/*/ ; do
    	[ "$(dirname "$d")" = "/home" ] && ! id "$(basename "$d")" &>/dev/null && continue	# Skip dirs that no are homes
	
		# Create config folders if no exists
		d="$d/.config/autostart"; [ ! -d "$d" ] && mkdir -v -p "$d" && cp -r /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/color_temperature_adjuster_gui/tray_redshift.desktop "$d" && chown -R $(stat "$(dirname "$d")" -c %u:%g) "$d"
		d="$d/.config/redshift"; [ ! -d "$d" ] && mkdir -v -p "$d" && cp -r /usr/share/DmDmDmdMdMdM/bin/not_add_2_path/color_temperature_adjuster_gui/redshift.conf "$d" && chown -R $(stat "$(dirname "$d")" -c %u:%g) "$d"
	done
	
	remove_from_db
	
	say
	say "${app_name} has been installed successfully."
	say
	say 'Hit any key to exit...'
	read -srn1
	
	color_temperature_adjuster_gui
	
	break
done

