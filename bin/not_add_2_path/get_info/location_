#!/usr/bin/env bash
get_date_from_here=""
list_to_test=(debian.com ipinfo.io 104.16.132.229)
	
for test in "${list_to_test[@]}";do
	ping -c 1 $test &>/dev/null && get_date_from_here="$test" && break
done
		
if [ -z "$get_date_from_here" ];then 
	echo "failed to ping all of this: ${list_to_test[@]}"
else
	curl -s https://ipinfo.io/ 2>/dev/null | grep timezone | awk -F: '{print $2}' | sed 's/"//g;s/,//g;s/ //g'
fi
