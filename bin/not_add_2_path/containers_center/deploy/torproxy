#!/usr/bin/env bash
set -e

script_full_path="$(realpath "$0")"
script_path="$(dirname ${script_full_path})"
container_name="$(basename ${script_full_path})"

containers_main_path="$(dirname ${script_path})"
extra_folder="${containers_main_path}/extra/${container_name}"
deployed_folder="${containers_main_path}/deployed/${container_name}"

if command -v sudo &>/dev/null;then
	__sudo="sudo"
else
	__sudo=""
fi

###################################################################
. "/usr/share/DmDmDmdMdMdM/lib/common/Package-manager"

while true; do # do it until the package is successfully installed or user wants to exit
	if [[ $TRYAGAIN ]]; then # previous try failed
		say
		say "There was a problem installing ${container_name}."
		say
		prompt '  Hit any key to try again, or "q" to quit...' Q && break
	fi
	TRYAGAIN=true
	
	clear
	say
	say "INSTALL ${container_name}."
	say '------------------------'
	say "This script will install ${container_name}."
	say
	prompt '  Run the installer now?' || break
	
	sudo true
	keep_Sudo_refresed &
	
	clear
	connectiontest 1 || continue
	
	clear
	say 'Updating sources...' 1
	Package_update_
	
	clear
	say 'install container software ...' 1
	
	my-installer --container-software --skip-test
	
	say 'Createing container image ...' 1

	cd "${extra_folder}"
	
	./installer
	
	$__sudo touch "${deployed_folder}"
	
	remove_from_db
	
	say
	say "${app_name} has been installed successfully."
	say
	say 'Hit any key to exit...'
	read -srn1
	break
done
[[ "$CONTAINER_RT" = "docker" ]] && newgrp docker
