#!/usr/bin/env sh
#### Fix missing files        ########################################################################

. "/usr/share/my_stuff/lib/common/WM"

if mkdir -p "/tmp/$USER";then
	chmod 700 "/tmp/$USER"
else
	echo "$0: ERROR failed to create /tmp/$USER"
fi

if [ ! -f "${WM_config_dir}/rofi_picked" ];then
	panel_manager --picker
	style-manager --set
	touch "${WM_config_dir}/rofi_picked"
fi

#### START SETTINGS  #################################################################################

# Exec first script screenlayout found
if [ "$(ls -A ~/.screenlayout >/dev/null 2>&1)" ] 
then
	"$(ls ~/.screenlayout/*.sh | head -1)"
else
	displayselect auto
fi

# Start keyring	
keyring-session &

## Start Music Player Daemon
mpd-session &

# Set wallpaper
setbg -r


## Notification Daemon
dunst-session  &

## file-manager Daemon
file-manager-session &

