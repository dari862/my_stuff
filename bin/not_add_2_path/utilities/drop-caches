#!/bin/bash
# clear system cache
set -eu

if [ -e /proc/sys/vm/drop_caches ]; then
  sync
  my-superuser bash -c "echo 3 > /proc/sys/vm/drop_caches"
  echo "Done!"
elif ( ! command -v purge > /dev/null ) && [[ "${OSTYPE}" == "darwin"* ]]; then
  sync
  my-superuser purge
else
  echo "Not possible..."
  exit 3
fi
