            if is_on: self.audio_codec_frame.pack(fill="x", padx=15, pady=(2, 6), before=self.behavior_rows["ALWAYS ON TOP (?)"])
            else: self.audio_codec_frame.pack_forget()
        elif behavior_name == "RECORD FEED (?)":
            if is_on: self.record_path_frame.pack(fill="x", padx=15, pady=(2, 6), after=self.behavior_rows["RECORD FEED (?)"])
            else: self.record_path_frame.pack_forget()
            
        self.update_live_command_preview()

