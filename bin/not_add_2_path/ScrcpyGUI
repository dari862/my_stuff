    # ==========================================
    # CORE ADB & SCRCPY EXECUTION PIPELINE
    # ==========================================
    def build_scrcpy_arguments(self):
        """Compiles active GUI configurations and maps them to an array of arguments."""
        scrcpy_args = ["scrcpy"]
        if self.config_state["device_id"] != "No Device Detected":
            scrcpy_args.extend(["-s", self.config_state["device_id"]])

        # 1. Parse Capture Source Profiles
        source = self.config_state["capture_source"]
        if source == "CAMERA":
            scrcpy_args.append("--video-source=camera")
            if "Auto" not in self.config_state["camera_id"]:
                scrcpy_args.append(f"--camera-id={self.config_state['camera_id']}")
            scrcpy_args.append(f"--video-codec={self.config_state['camera_codec'].lower()}")
            if "Original" not in self.config_state["aspect_ratio"]:
                scrcpy_args.append(f"--camera-ar={self.config_state['aspect_ratio']}")
            if self.config_state["camera_torch"]:
                scrcpy_args.append("--camera-fps=30")
        elif source == "DESKTOP":
            scrcpy_args.append(f"--create-vdisplay={self.config_state['desktop_width']}x{self.config_state['desktop_height']}")

        # 2. Add General Stream Modifiers
        if self.config_state["resolution"] != "Original":
            res_val = self.config_state["resolution"].replace("p", "")
            scrcpy_args.append(f"-m{res_val}")
            
        if self.config_state["fps"] != "Auto":
            scrcpy_args.append(f"--max-fps={self.config_state['fps']}")
            
        if self.config_state["rotation"] != "0°":
            rot_deg = self.config_state["rotation"].replace("°", "")
            rot_map = {"90": "1", "180": "2", "270": "3"}
            scrcpy_args.append(f"--lock-video-orientation={rot_map.get(rot_deg, '0')}")

        scrcpy_args.append(f"-b{self.config_state['bitrate']}M")

        # 3. Handle Native Session Management Rules 
        rules = self.config_state["session_behaviors"]
        if rules["STAY AWAKE (?)"]: scrcpy_args.append("-w")
        if rules["SCREEN OFF (?)"]: scrcpy_args.append("-S")
        if rules["ALWAYS ON TOP (?)"]: scrcpy_args.append("--always-on-top")
        if rules["FULL SCREEN (?)"]: scrcpy_args.append("-f")
        if rules["BORDERLESS (?)"]: scrcpy_args.append("--window-borderless")
        
        if rules["FORWARD AUDIO (?)"]:
            scrcpy_args.append(f"--audio-codec={self.config_state['audio_codec'].lower()}")
        else:
            scrcpy_args.append("--no-audio")

        if rules["RECORD FEED (?)"]:
            # Uses a snapshot generator for path representation previewing
            timestamp = "YYYYMMDD_HHMMSS"
            record_file = os.path.join(self.config_state["recording_path"], f"scrcpy_stream_{timestamp}.mp4")
            scrcpy_args.append(f"-r={record_file}")

        # 4. Input Enhancements (OTG simulation drivers)
        if self.config_state["hid_keyboard"]: scrcpy_args.append("-K")
        if self.config_state["hid_mouse"]: scrcpy_args.append("-M")

        return scrcpy_args

    def update_live_command_preview(self):
        """Updates the command text bar visibility safely stringwise."""
        args = self.build_scrcpy_arguments()
        self.preview_text.configure(state="normal")
        self.preview_text.delete(0, "end")
        self.preview_text.insert(0, " ".join(args))
        self.preview_text.configure(state="readonly")

    def run_background_cmd(self, cmd_list, callback=None, log_output=True):
        """Executes a terminal or shell tool safely inside a worker thread to keep the GUI fluid."""
        def worker():
            try:
                startupinfo = None
                if os.name == 'nt':
                    startupinfo = subprocess.STARTUPINFO()
                    startupinfo.dwFlags |= subprocess.STARTF_USESHOWWINDOW
                
                result = subprocess.run(
                    cmd_list, 
                    stdout=subprocess.PIPE, 
                    stderr=subprocess.PIPE, 
                    text=True, 
                    startupinfo=startupinfo,
                    timeout=120
                )
                if log_output and result.stdout.strip():
                    self.log_to_console(f"[SHELL OUT] {result.stdout.strip()}")
                if result.returncode != 0 and result.stderr.strip():
                    self.log_to_console(f"[SHELL ERR] {result.stderr.strip()}", is_error=True)
                
                if callback:
                    self.after(0, lambda: callback(result.stdout, result.stderr))
            except Exception as e:
                self.log_to_console(f"Subprocess runtime error: {str(e)}", is_error=True)

        threading.Thread(target=worker, daemon=True).start()

    def refresh_adb_device_data(self):
        """Polls connected hardware via adb, extracts identifiers, and sniffs networking profiles."""
        self.log_to_console("🔍 Querying ADB subsystem layer for connected targets...")
        
        def process_devices(stdout, stderr):
            lines = stdout.strip().split('\n')
            devices = [line.split('\t')[0] for line in lines[1:] if line.strip() and '\tdevice' in line]
            
            if devices:
                active_device = devices[0]
                self.config_state["device_id"] = active_device
                self.lbl_dev.configure(text=f"{active_device}\nREADY  •  CONNECTED", text_color=("#4A4160", "#4AF2A1"))
                self.log_to_console(f"Active Device identified -> Host Interface ID: {active_device}")
                
                self.run_background_cmd(
                    ["adb", "-s", active_device, "shell", "ip", "route"], 
                    callback=process_ip, 
                    log_output=False
                )
            else:
                self.config_state["device_id"] = "No Device Detected"
                self.lbl_dev.configure(text="NO DEVICE RUNNING\nCHECK PHYSICAL LINK OR DRIVERS", text_color=("#FF4136", "#FF6B6B"))
                self.log_to_console("Warning: ADB found no initialized devices. Verify USB Debugging setup.", is_error=True)
            self.update_live_command_preview()

        def process_ip(stdout, stderr):
            match = re.search(r'src\s+([\d\.]+)', stdout)
            if match:
                ip = match.group(1)
                self.config_state["wireless_ip"] = f"{ip}:5555"
                self.log_to_console(f"Target system wireless interface recognized -> {ip}")
                if hasattr(self, 'ip_entry') and self.ip_entry.winfo_exists():
                    self.ip_entry.delete(0, "end")
                    self.ip_entry.insert(0, f"{ip}:5555")
            else:
                self.log_to_console("Device has no active WLAN routing assigned. Connect phone to shared WiFi topology.")

        self.run_background_cmd(["adb", "devices"], callback=process_devices, log_output=False)

    def trigger_wireless_connect(self):
        """Instructs ADB to connect to a target network node address over TCP/IP."""
        target_ip = self.config_state["wireless_ip"].strip()
        if not target_ip:
            self.log_to_console("Error: Please provide a valid address string (IP:PORT).", is_error=True)
            return
        
        self.log_to_console(f"Bridging target link interface context to TCP over port 5555...")
        self.run_background_cmd(["adb", "tcpip", "5555"], callback=lambda out, err: self.after(1000, lambda: self.run_background_cmd(["adb", "connect", target_ip], callback=lambda o, e: self.refresh_adb_device_data())))

    def trigger_wireless_pairing(self):
        """Executes modern Android 11+ automated pairing keys."""
        ip_port = self.config_state["pairing_ip"].strip()
        code = self.config_state["pairing_code"].strip()
        if not ip_port or not code:
            self.log_to_console("Pairing parameters incomplete. Check values.", is_error=True)
            return
        self.log_to_console(f"Broadcasting security protocol handshake parameters toward -> {ip_port}")
        self.run_background_cmd(["adb", "pair", ip_port, code], callback=lambda o, e: self.refresh_adb_device_data())

    def kill_adb_daemon(self):
        """Restarts the system bridge daemon context to handle communication issues."""
        self.log_to_console("Killing host ADB daemon instances...")
        self.run_background_cmd(["adb", "kill-server"], callback=lambda o, e: self.refresh_adb_device_data())

    # ==========================================
    # FILE UPLOAD LOGIC ENGINE
    # ==========================================
    def process_file_upload(self, filepath):
        """Determines if target payload file is an APK installer or general asset file, then executes push."""
        filepath = filepath.strip('{} ') 
        if not filepath or not os.path.exists(filepath):
            self.log_to_console("File interaction failed: Specified storage path does not exist.", is_error=True)
            return

        if self.config_state["device_id"] == "No Device Detected":
            self.log_to_console("Cannot dispatch files: No initialized Android hardware mapped.", is_error=True)
            return

        filename = os.path.basename(filepath)
        
        if filename.lower().endswith(".apk"):
            self.log_to_console(f"📦 System packaging detected. Initiating background app installation layer for: {filename}")
            cmd = ["adb", "-s", self.config_state["device_id"], "install", "-r", filepath]
            
            def on_install_complete(stdout, stderr):
                if "Success" in stdout or "Success" in stderr:
                    self.log_to_console(f"🎉 Success! Package '{filename}' safely installed on target device.")
                else:
                    self.log_to_console(f"⚠️ App Installation completed with anomaly status markers.", is_error=True)
            
            self.run_background_cmd(cmd, callback=on_install_complete)
        else:
            destination = "/sdcard/Download/"
            self.log_to_console(f"📁 Asset file verified. Dispatched adb push stream for '{filename}' to system repository: {destination}")
            cmd = ["adb", "-s", self.config_state["device_id"], "push", filepath, destination]
            
            def on_push_complete(stdout, stderr):
                self.log_to_console(f"📤 File allocation synchronized! Transfer for '{filename}' committed to {destination}")
            
            self.run_background_cmd(cmd, callback=on_push_complete)

    def manual_file_selector_trigger(self, event=None):
        """Opens a standard file dialog option when users click inside the payload card container."""
        chosen_file = filedialog.askopenfilename(title="Select File / Application Package to push to device")
        if chosen_file:
            self.process_file_upload(chosen_file)

    def handle_connection_startup(self):
        """Compiles GUI configurations and maps them seamlessly to an optimized scrcpy statement."""
        if self.config_state["device_id"] == "No Device Detected":
            self.log_to_console("Aborting SCRCPY init thread: Target system requires an active device map link.", is_error=True)
            return

        scrcpy_args = self.build_scrcpy_arguments()
        
        # Swaps representative runtime string elements with real hardware timestamp parameters
        if self.config_state["session_behaviors"]["RECORD FEED (?)"]:
            real_ts = datetime.now().strftime("%Y%m%d_%H%M%S")
            scrcpy_args = [arg.replace("YYYYMMDD_HHMMSS", real_ts) for arg in scrcpy_args]

        self.log_to_console(f"Launching scrcpy runtime engine context using syntax: {' '.join(scrcpy_args)}")
        
        def launch_scrcpy_instance():
            try:
                startupinfo = None
                if os.name == 'nt':
                    startupinfo = subprocess.STARTUPINFO()
                    startupinfo.dwFlags |= subprocess.STARTF_USESHOWWINDOW
                proc = subprocess.Popen(scrcpy_args, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, startupinfo=startupinfo)
                stdout, stderr = proc.communicate()
                if stdout.strip(): self.log_to_console(f"[SCRCPY] {stdout.strip()}")
                if stderr.strip(): self.log_to_console(f"[SCRCPY OUT] {stderr.strip()}")
            except Exception as e:
                self.log_to_console(f"Fatal error deploying target screen link: {str(e)}", is_error=True)

        threading.Thread(target=launch_scrcpy_instance, daemon=True).start()

    # ==========================================
    # GLOBAL THEME & LOGGING VIEWPORT TOOLS
    # ==========================================
    def change_theme_mode(self, choice):
        if choice == "Light Mode":
            ctk.set_appearance_mode("light")
        elif choice == "Dark Mode":
            ctk.set_appearance_mode("dark")
        else:
            ctk.set_appearance_mode("system")
        self.log_to_console(f"Visual engine theme switched to: {choice}")

    def log_to_console(self, text, is_error=False):
        timestamp = datetime.now().strftime("%H:%M:%S")
        prefix = "[ERROR] " if is_error else "[INFO]  "
        formatted_msg = f"[{timestamp}] {prefix}{text}\n"
        
        self.console_box.configure(state="normal")
        self.console_box.insert("end", formatted_msg)
        self.console_box.see("end")
        self.console_box.configure(state="disabled")

    def clear_console_logs(self):
        self.console_box.configure(state="normal")
        self.console_box.delete("1.0", "end")
        self.console_box.configure(state="disabled")
        self.log_to_console("Console log display cleared.")

    def save_console_to_file(self):
        log_content = self.console_box.get("1.0", "end-1c")
        if not log_content.strip(): return
        file_path = filedialog.asksaveasfilename(defaultextension=".txt", filetypes=[("Text Files", "*.txt"), ("Log Files", "*.log")], title="Save Console Output As...")
        if file_path:
            with open(file_path, "w", encoding="utf-8") as f:
                f.write(log_content)
            self.log_to_console(f"Logs exported successfully to: {os.path.basename(file_path)}")

    def execute_terminal_command(self, event=None):
        raw_cmd = self.cmd_entry.get().strip()
        if not raw_cmd: return
        self.log_to_console(f"Running custom shell script override argument line: {raw_cmd}")
        cmd_split = raw_cmd.split(" ")
        if cmd_split[0].lower() in ["clear", "cls"]:
            self.clear_console_logs()
        else:
            self.run_background_cmd(cmd_split)
        self.cmd_entry.delete(0, "end")

    def on_shortcut_click(self, key_pressed):
        self.log_to_console(f"Macro shortcut event triggered: ALT + {key_pressed}")
        if self.config_state["device_id"] != "No Device Detected":
            self.run_background_cmd(["adb", "-s", self.config_state["device_id"], "shell", "input", "keyevent", "KEYWORDS_IF_ANY"])

