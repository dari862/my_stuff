        right_container.grid(row=0, column=2, padx=15, pady=15, sticky="nsew")

        behavior_card = ctk.CTkFrame(right_container, fg_color=("#FFFFFF", "#2A2438"), corner_radius=12, border_color=("#E2E0E7", "#3D354E"), border_width=1)
        behavior_card.pack(fill="x", pady=(0, 15), ipady=10)

        lbl_session = ctk.CTkLabel(behavior_card, text="⚙️ SESSION BEHAVIOR", font=("Arial", 12, "bold"), text_color=("#5A5568", "#C3BCDB"))
        lbl_session.pack(anchor="w", padx=15, pady=10)

        self.audio_codec_frame = ctk.CTkFrame(behavior_card, fg_color="transparent")
        ctk.CTkLabel(self.audio_codec_frame, text="AUDIO CODEC", font=("Arial", 10, "bold"), text_color="#845EF7").pack(side="left", padx=(20, 0))
        self.drop_codec = ctk.CTkOptionMenu(self.audio_codec_frame, values=["Opus", "AAC", "RAW"], fg_color=("#F1EFF5", "#1E1A29"), text_color=("#4A4160", "#E3DFFE"), button_color=("#F1EFF5", "#1E1A29"), width=95, height=22, command=lambda val: self.update_dropdown_state("audio_codec", val))
        self.drop_codec.set(self.config_state["audio_codec"])
        self.drop_codec.pack(side="right")

        # Configured frame box for path management components
        self.record_path_frame = ctk.CTkFrame(behavior_card, fg_color=("#F1EFF5", "#1E1A29"), corner_radius=6, border_color=("#D1CDDA", "#342E44"), border_width=1, height=32)
        self.record_path_frame.pack_propagate(False)
        
        trunc_init_path = self.config_state["recording_path"] if len(self.config_state["recording_path"]) <= 28 else f"...{self.config_state['recording_path'][-25:]}"
        self.lbl_path_value = ctk.CTkLabel(self.record_path_frame, text=trunc_init_path, font=("Arial", 10, "bold"), text_color=("#5A5568", "#C3BCDB"))
        self.lbl_path_value.pack(side="left", padx=10)
        
        btn_browse = ctk.CTkButton(self.record_path_frame, text="BROWSE", font=("Arial", 9, "bold"), fg_color=("#E2E0E7", "#342E44"), hover_color=("#D1CDDA", "#443C59"), text_color=("#4A4160", "#E3DFFE"), width=65, height=22, command=self.browse_recording_path)
        btn_browse.pack(side="right", padx=5)

        self.behavior_rows = {}
        
        for text, default_on in self.config_state["session_behaviors"].items():
            row = ctk.CTkFrame(behavior_card, fg_color="transparent")
            row.pack(fill="x", padx=15, pady=5)
            self.behavior_rows[text] = row
            
            ctk.CTkLabel(row, text=text, font=("Arial", 11), text_color=("#4A4160", "#E3DFFE")).pack(side="left")
            
            sw = ctk.CTkSwitch(row, text="", progress_color="#845EF7", button_color="#845EF7")
            if default_on: 
                sw.select()
            sw.configure(command=lambda t=text, s=sw: self.update_behavior_switch(t, s))
            sw.pack(side="right")

        # --- PACK POSITION MANAGEMENT MARGIN RULES ---
        if self.config_state["session_behaviors"]["FORWARD AUDIO (?)"]:
            self.audio_codec_frame.pack(fill="x", padx=15, pady=(2, 6), before=self.behavior_rows["ALWAYS ON TOP (?)"])
            
        # MODIFIED: Places recording target options frame panel row directly *AFTER* the record switch
        if self.config_state["session_behaviors"]["RECORD FEED (?)"]:
            self.record_path_frame.pack(fill="x", padx=15, pady=(2, 6), after=self.behavior_rows["RECORD FEED (?)"])

        shortcuts_card = ctk.CTkFrame(right_container, fg_color=("#FFFFFF", "#2A2438"), corner_radius=12, border_color=("#E2E0E7", "#3D354E"), border_width=1)
        shortcuts_card.pack(fill="x", pady=0, ipady=10)

        lbl_shortcuts = ctk.CTkLabel(shortcuts_card, text="⌨️ SHORTCUTS (ALT +)", font=("Arial", 12, "bold"), text_color=("#5A5568", "#C3BCDB"))
        lbl_shortcuts.pack(anchor="w", padx=15, pady=10)

        grid_frame = ctk.CTkFrame(shortcuts_card, fg_color="transparent")
        grid_frame.pack(fill="x", padx=15, pady=5)
        grid_frame.columnconfigure((0, 1, 2, 3), weight=1)

        shortcut_items = [
            {"icon": "⛶", "key": "F"}, {"icon": "🏠", "key": "H"}, 
            {"icon": "❬", "key": "B"}, {"icon": "☰", "key": "S"},
            {"icon": "⏻", "key": "P"}, {"icon": "⟳", "key": "R"}, 
            {"icon": "📋", "key": "V"}, {"icon": "👁", "key": "O"}
        ]

        for index, item in enumerate(shortcut_items):
            r = index // 4
            c = index % 4
            
            item_box = ctk.CTkFrame(grid_frame, fg_color="transparent")
            item_box.grid(row=r, column=c, padx=4, pady=8, sticky="nsew")
            
            lbl_icon = ctk.CTkLabel(item_box, text=item["icon"], font=("Arial", 16), text_color=("#4A4160", "#E3DFFE"))
            lbl_icon.pack()
            
            btn_key = ctk.CTkButton(
                item_box, 
                text=item["key"], 
                font=("Arial", 10, "bold"), 
                text_color=("#5A5568", "#E3DFFE"),
                fg_color=("#F1EFF5", "#1E1A29"), 
                hover_color=("#D1CDDA", "#342E44"),
                border_color=("#D1CDDA", "#342E44"),
                border_width=1,
                corner_radius=4, 
                width=26, 
                height=22,
                command=lambda k=item["key"]: self.on_shortcut_click(k)
            )
            btn_key.pack(pady=(4, 0))


if __name__ == "__main__":
    app = DynamicScrcpyGUI()
    app.mainloop()
