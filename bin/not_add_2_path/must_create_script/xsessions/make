#!/bin/sh
set -e
. "/usr/share/my_stuff/lib/common/WM"
path_to_files="/usr/share/my_stuff/bin/not_add_2_path/must_create_script/xsessions"
my-superuser mkdir -p /usr/share/my_stuff/system_files/bin/xsessions

cat "${path_to_files}/main" | my-superuser tee /usr/share/my_stuff/system_files/bin/xsessions/openbox > /dev/null 2>&1
echo "echo 'openbox' | tee \"\$HOME/$WM_config_dir_name/$WM_name_file_name\" >/dev/null 2>&1" | my-superuser tee -a /usr/share/my_stuff/system_files/bin/xsessions/openbox > /dev/null 2>&1
cat "/usr/share/my_stuff/lib/common/openbox" "${path_to_files}/openbox.sh" | my-superuser tee -a /usr/share/my_stuff/system_files/bin/xsessions/openbox > /dev/null 2>&1


cat "${path_to_files}/main" | my-superuser tee /usr/share/my_stuff/system_files/bin/xsessions/bspwm > /dev/null 2>&1
echo "echo 'bspwm' | tee \"\$HOME/$WM_config_dir_name/$WM_name_file_name\" >/dev/null 2>&1" | my-superuser tee -a /usr/share/my_stuff/system_files/bin/xsessions/bspwm > /dev/null 2>&1
cat "${path_to_files}/bspwm.sh" | my-superuser tee -a /usr/share/my_stuff/system_files/bin/xsessions/bspwm > /dev/null 2>&1

my-superuser chmod +x /usr/share/my_stuff/system_files/bin/xsessions/*
