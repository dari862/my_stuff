#!/bin/sh

if [ -f /usr/share/my_stuff/system_files/this_is_laptop ];then
	if command -v xbacklight &> /dev/null; then
		pak=xbacklight
	elif command -v light &> /dev/null; then
		pak=light
	else
		echo -e "$0: light or xbacklight not installed."
		exit 1
	fi
	
	cat head $pak tail | sudo tee /usr/share/my_stuff/system_files/bin/brightness
	sudo chmod +x /usr/share/my_stuff/system_files/bin/brightness
fi
