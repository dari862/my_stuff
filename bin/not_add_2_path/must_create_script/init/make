#!/bin/sh
set -e

# openrc
if command -v rc-service &> /dev/null; then
	sudo ln -sf /usr/share/my_stuff/bin/not_add_2_path/init/openrc /usr/share/my_stuff/system_files/bin/service_manager
# systemd	
else
	sudo ln -sf /usr/share/my_stuff/bin/not_add_2_path/init/systemd /usr/share/my_stuff/system_files/bin/service_manager
fi
