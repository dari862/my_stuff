#!/bin/sh
. "/usr/share/my_stuff/lib/common/WM"
. "/usr/share/my_stuff/lib/common/openbox"
. "/usr/share/my_stuff/lib/common/DB"

picked_style_are="${1-}"
if [ "${picked_style_are}" = "normal" ];then
	[ -f "${OB_STYLE_BL}" ] && rm "${OB_STYLE_BL}"
	[ -f "${OB_STYLE_NORMAL}" ] && rm "${OB_STYLE_NORMAL}"
	[ -f "${styles_db_path}" ] && rm "${styles_db_path}"
	touch "${OB_STYLE_NORMAL}"
elif [ "${picked_style_are}" = "bl" ];then
	[ -f "${OB_STYLE_BL}" ] && rm "${OB_STYLE_BL}"
	[ -f "${OB_STYLE_NORMAL}" ] && rm "${OB_STYLE_NORMAL}"
	[ -f "${styles_db_path}" ] && rm "${styles_db_path}"
	touch "${OB_STYLE_BL}"
fi
