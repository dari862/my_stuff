#!/usr/bin/env bash
set -e

distro_name="kali"

script_full_path="$(dirname "$(realpath "$0")")"
cd "${script_full_path}"

__format=""

if [[ "$CONTAINER_RT" = "podman" ]];then
	__format='--format docker'
fi

mode=""
if [[ "$mode" == "root" ]]; then
        root_command="--root"
else
        root_command=""
fi

prefix="$HOME/.local/distrobox"
tmp_folder=""
xsession_kali=""

Pre_createing_container_image(){
	tmp_folder=$(mktemp -d /tmp/${distro_name}-container-XXXXXXXX)
	mkdir -p "$HOME/.local/distrobox/$distro_name"
}

wm_kali_linux(){
	__WM_="kali-desktop-i3 i3blocks rofi acpid dunst feh playerctl alsa-utils xbacklight wireless-tools network-manager"
	__wm_command="sudo apt-get install -yq ${__WM_} ; exit 0"
	__arg_="${1-}"
	if [[ "${__arg_}" = "ask" ]];then
		read -p '  Do you want to add kali to xsession? (yes or no [default yes])' xsession_kali
		[[ -z "$xsession_kali" ]] && xsession_kali="yes"
		xsession_kali="${xsession_kali,,}"
		[[ "$xsession_kali" = "^y " ]] && xsession_kali="yes"
		if [[ "$xsession_kali" = "yes" ]];then
			xsession_kali="enabled"
		fi
	else
		if [[ $xsession_kali == "enabled" ]]; then
			distrobox enter --name "$distro_name" ${root_command} -- "${__wm_command}"
			my-superuser ln -sf /usr/share/my_stuff/bin/not_add_2_path/distrobox_center/Extra/Extra/kali/i3/kali-i3.desktop /usr/share/xsessions/
			mkdir -p "$prefix/$distro_name"/.config
			cp -r /usr/share/my_stuff/bin/not_add_2_path/distrobox_center/Extra/kali_i3/.config/* "$prefix/$distro_name"/.config
		fi
	fi
}



###################################################################
say 'Pre-createing container image ...' 1

Pre_createing_container_image || failed_to_run "failed to install Pre-createing container image."

say 'Createing container image ...' 1
CONTAINER_RT build -t ${distro_name} . ${__format} --no-cache

say 'Deploy container image ...' 1
distrobox create --image "local/${distro_name}" \
         --name "$distro_name" \
         --home "$prefix/$distro_name" ${root_command} || failed_to_run "failed to deploy container image."

say 'Createing container lanucher ...' 1
echo '#!/bin/bash' > "${tmp_folder}/${distro_name}"
echo "distrobox enter --name \"$distro_name\" ${root_command} " >> "${tmp_folder}/${distro_name}"

chmod +x "${tmp_folder}/${distro_name}"
mkdir -p "$HOME/.local/bin"
mv "${tmp_folder}/${distro_name}" "$HOME/.local/bin"

#wm_kali_linux || failed_to_run "failed to install ${__WM_}."

distrobox stop "$distro_name" --yes ${root_command}


say "${distro_name} successfully depolyed."
say
say "type ${distro_name} to use it."
say
