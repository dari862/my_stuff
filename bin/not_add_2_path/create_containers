#!/bin/bash
. "/usr/share/my_stuff/lib/common/includes_functions"

container_name="${1-}"
containers_installer_path="/usr/share/my_stuff/bin/not_add_2_path/containers_installer"
container_path="${containers_installer_path}/${container_name}"

if [ -n "${container_name}" ];then
	if [ -f "${container_path}" ];then
		. "${container_path}"
	else
		say " ERROR: failed to locate container: ${container_name} "
		say " ERROR: path: ${container_path}"
		exit 1
	fi
else
	ls -p "${containers_installer_path}" | grep -v "/"
	exit 1
fi
