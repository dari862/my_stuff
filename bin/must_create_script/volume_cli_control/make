#!/bin/sh
if command -v pactl > /dev/null 2>&1; then
	pak=pactl
elif command -v pulsemixer > /dev/null 2>&1; then
	pak=pulsemixer
elif command -v amixer > /dev/null 2>&1; then
	pak=amixer
else
	echo "$0: pactl or pulsemixer not installed."
	exit 1
fi

cat head $pak tail | my-superuser tee /usr/share/my_stuff/system_files/bin/volume_cli_control > /dev/null 2>&1
my-superuser chmod +x /usr/share/my_stuff/system_files/bin/volume_cli_control
