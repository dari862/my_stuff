#!/bin/sh
usr_session_name=$(basename "$0")
usr_confdir="${XDG_CONFIG_HOME:-$HOME/.config}"
usr_locl_share_dir="$HOME/.local/share"
usr_setup_flag_file="$usr_locl_share_dir/usr-flag-setup"
usr_xsessionrc="$HOME/.xsessionrc"
usr_resources="$HOME/.config/x11/xresources"
global_usr_xsessionrc="/usr/share/DmDmDmdMdMdM/lib/xsessionrc/xsessionrc"

# include DmDmDmdMdMdM/bin/laptop in PATH
if [ -f "/usr/share/DmDmDmdMdMdM/this_is_laptop" ];then
	if [ -d "/usr/share/DmDmDmdMdMdM/bin/laptop" ] ; then
		PATH="/usr/share/DmDmDmdMdMdM/bin/laptop:$PATH"
	fi
fi

# include DmDmDmdMdMdM/bin/bin in PATH
if [ -d "/usr/share/DmDmDmdMdMdM/bin/bin" ] ; then
	PATH="/usr/share/DmDmDmdMdMdM/bin/bin:$PATH"
fi

# include DmDmDmdMdMdM/bin/apps in PATH
if [ -d "/usr/share/DmDmDmdMdMdM/bin/apps" ] ; then
	PATH="/usr/share/DmDmDmdMdMdM/bin/apps:$PATH"
fi
# include DmDmDmdMdMdM/bin/rofi in PATH
if [ -d "/usr/share/DmDmDmdMdMdM/bin/rofi" ] ; then
	PATH="/usr/share/DmDmDmdMdMdM/bin/rofi:$PATH"
fi
# include DmDmDmdMdMdM/bin/polybar in PATH
if [ -d "/usr/share/DmDmDmdMdMdM/bin/polybar" ] ; then
	PATH="/usr/share/DmDmDmdMdMdM/bin/polybar:$PATH"
fi
# include DmDmDmdMdMdM/bin/apps in PATH
if [ -d "/usr/share/DmDmDmdMdMdM/bin/session_managers" ] ; then
	PATH="/usr/share/DmDmDmdMdMdM/bin/session_managers:$PATH"
fi

if [ "$usr_session_name" = "openbox" ]
then
	usr_autostart="$usr_confdir/${usr_session_name}/autostart"
	usr_envfile="$usr_confdir/${usr_session_name}/environment"
	default_autostart='/usr/share/DmDmDmdMdMdM/skel/.config/openbox'
		
	# include DmDmDmdMdMdM/bin/openbox in PATH
	if [ -d "/usr/share/DmDmDmdMdMdM/bin/openbox" ] ; then
    	PATH="/usr/share/DmDmDmdMdMdM/bin/openbox:$PATH"
	fi
	
	if [ -d "/usr/share/DmDmDmdMdMdM/bin/openbox/pipemenu" ] ; then
    	PATH="/usr/share/DmDmDmdMdMdM/bin/openbox/pipemenu:$PATH"
	fi
	# Clean up after GDM (GDM sets the number of desktops to one).
	xprop -root -remove _NET_NUMBER_OF_DESKTOPS \
      	-remove _NET_DESKTOP_NAMES \
      	-remove _NET_CURRENT_DESKTOP 2> /dev/null
	
elif [ "$usr_session_name" = "bspwm" ]
then
	usr_autostart="$usr_confdir/${usr_session_name}/bspwmrc"
	default_autostart='/usr/share/DmDmDmdMdMdM/skel/.config/bspwm'
	
	# include DmDmDmdMdMdM/bin/bin in PATH
	if [ -d "/usr/share/DmDmDmdMdMdM/bin/bin" ] ; then
    	PATH="/usr/share/DmDmDmdMdMdM/bin/bspwm:$PATH"
	fi
fi

# This section is only executed on first boot.
if [ ! -f "$usr_setup_flag_file" ];then
	
	if [ -f "$global_usr_xsessionrc" ];then
		. "$global_usr_xsessionrc" 
	else
		echo "$0: cannot source $global_usr_xsessionrc" >&2
	fi
	
    # Import user config files
    if [ -x /usr/share/DmDmDmdMdMdM/bin/xsession/skel_user_setup_ ];then
        /usr/share/DmDmDmdMdMdM/bin/xsession/skel_user_setup_ "$usr_setup_flag_file" || failed_to_run_skel_user_setup_=true
    fi
    
    if [ "$failed_to_run_skel_user_setup_" = true ]
	then
		/usr/share/DmDmDmdMdMdM/bin/xsession/skel_user_setup_ "$usr_setup_flag_file" || echo "failed to run skel_user_setup_"
	fi
	
    # Actions here are usually handled by scripts in /etc/X11/Xsession.d/
    # but on first boot, user config files were not yet imported at that point.
    # This makes a difference to the live session, unless user logs out/in.

    # Merge ~/.Xresources
    # (usually done by /etc/X11/Xsession.d/30x11-common_xresources)
    test -r "$usr_resources" && xrdb -merge "$usr_resources" || echo "$0: cannot merge $usr_resources" >&2

    # Set up the user environment for X sessions.
    # (usually sourced by /etc/X11/Xsession.d/40x11-common_xsessionrc)
    #test -r "$usr_xsessionrc" && . "$usr_xsessionrc" || echo "$0: cannot source $usr_xsessionrc" >&2

    # Set up user directories
    # (usually run by /etc/X11/Xsession.d/60xdg-user-dirs-update)
    if [ -x /usr/bin/xdg-user-dirs-update ]; then
        /usr/bin/xdg-user-dirs-update
    fi
fi

# At least try to ensure user has an autostart file.
[ -e "$usr_autostart" ] || {
    echo "$0: ERROR $usr_autostart does not exist, copying in $default_autostart" >&2
    cp -r "$default_autostart" "$usr_confdir"
}


if [ "$usr_session_name" = "openbox" ]
then
	# Create DB for quick load menu
	/usr/share/DmDmDmdMdMdM/bin/not_add_2_path/create_DB.sh &
	
	# Set up the specific environment.
	test -r "$usr_envfile" && . "$usr_envfile" || echo "$0: cannot source $usr_envfile" >&2
	
	# Run Openbox, and have it run the autostart stuff
	exec /usr/bin/openbox --config-file "${usr_confdir}/openbox/rc.xml" --startup "/usr/share/DmDmDmdMdMdM/bin/xsession/openbox_files/openbox-autostart OPENBOX" "$@"	
	
elif [ "$usr_session_name" = "bspwm" ]
then
	exec /usr/bin/bspwm
fi
