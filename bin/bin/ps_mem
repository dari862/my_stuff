#!/bin/sh
#===================================================================================
tput civis

# Prompt for input text
echo "Text to highlight: "
read t

# Loop to continuously update the display
while true; do
    clear
    out=$(/usr/share/my_stuff/bin/not_add_2_path/ps_mem.py -S)
    outl=$(echo "$out" | wc -l)
    sl=$(tput lines)
    
    if [ "$sl" -lt "$outl" ]; then
        echo "$out" | sed -e "3,$((outl-sl+4))d"
    else
        echo "$out"
    fi
	sleep 2
	read input
done | grep -i --color=auto "^|$t"
