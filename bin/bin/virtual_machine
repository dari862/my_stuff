#!/bin/bash
    
if command -v virt-manager >/dev/null 2>&1; then
	virt-manager &
	exit
elif command -v virtualbox >/dev/null 2>&1; then
	virtualbox &
	exit
elif command -v vmplayer >/dev/null 2>&1; then
	vmplayer &
	exit
fi

my-installer --tweek "Enable_IOMMU_support" || (echo "Failed to enable IOMMU Support." && exit 1)

echo 'Do you want to install VirtualBox or Virt-manager?'
echo '[1 or m] for Virt-manager'
echo '[2 or b] for VirtualBox'
echo '[3 or v] for VMware player'
echo 'Defaulting to Virt-manager'
read -p " " -n 1 -r
[ -z $REPLY ] && REPLY="1"

if [[ $REPLY =~ ^[1mM]$ ]]; then
	source "/usr/share/my_stuff/bin/not_add_2_path/virt/virt-manager/virt-manager"
elif [[ $REPLY =~ ^[2bB]$ ]]; then
	source "/usr/share/my_stuff/bin/not_add_2_path/virt/virtualbox"
elif [[ $REPLY =~ ^[3vV]$ ]]; then
	source "/usr/share/my_stuff/bin/not_add_2_path/virt/vmplayer"
else
	echo "$0: no such install option $REPLY"
    exit 1
fi
clear 
echo ' --- Installtion Complated --- ' && read -p '  Press any key to exit'
