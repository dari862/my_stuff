#!/bin/sh
wallpapers_dir="/usr/share/my_stuff/my_wallpapers"

if command -v nitrogen >/dev/null 2>&1;then
	if [ ! -f "$HOME/.config/nitrogen/nitrogen.cfg" ];then
		tee "$HOME/.config/nitrogen/nitrogen.cfg" <<- EOF > /dev/null
		[geometry]
		posx=654
		posy=174
		sizex=508
		sizey=500
		
		[nitrogen]
		view=icon
		recurse=true
		sort=alpha
		icon_caps=false
		dirs=${wallpapers_dir}
		EOF
	fi
	nitrogen
else
	image_file=$(yad --file-selection --title="Select an Image" --filter="Images | *.png *.jpg *.jpeg *.gif *.bmp" --filename="/usr/share/my_stuff/my_wallpapers/" --add-preview --large-preview)
	if [ -n "$image_file" ];then
    	setbg -R "$image_file"
	fi
fi
