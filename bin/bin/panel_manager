#!/usr/bin/env bash
count=0
opt="${1-}"
opt2="${2-}"
config_dir="$HOME/.config"
openbox_conf_dir="${config_dir}/openbox"
lib_openbox_conf_dir="/usr/share/DmDmDmdMdMdM/lib/openbox_rc"
tint2_dir="${config_dir}/tint2"
default_panel="polybar"
. "/usr/share/DmDmDmdMdMdM/lib/common/rofi"
. "/usr/share/DmDmDmdMdMdM/lib/common/panel"
panel_picker() {
	mkdir -p "$which_panel_dir"
	
	if command -v polybar &> /dev/null
	then
		polybar_in_rofi="polybar"
		((++count))
		which_panel_MENU="polybar"
	fi
	
	if command -v xfce4-panel &> /dev/null
	then
		xfce4_in_rofi="|xfce4-panel"
		((++count))
		which_panel_MENU="xfce4-panel"
	fi
	if command -v tint2 &> /dev/null
	then
		tint2_in_rofi="|tint2"
		((++count))
		which_panel_MENU="tint2"
	fi
	
	if (( count > 1 )); then
		which_panel_MENU="$(rofi -no-config -no-lazy-grab -sep "|" -dmenu -i -p '' -no-click-to-exit \
		-theme "$rofi_style_dir"/launcher.rasi \
		<<< "${polybar_in_rofi}${xfce4_in_rofi}${tint2_in_rofi}")"
	fi
	
	if [ "$which_panel_MENU" == "polybar" ]; then
		cp -r "${lib_openbox_conf_dir}/DmDmDmdMdMdM_rc.xml" "${openbox_conf_dir}"
		echo "DmDmDmdMdMdM_rc.xml" > "${openbox_conf_dir}/rc_name"
	elif [ "$which_panel_MENU" == "xfce4-panel" ]; then
		cp -r "${lib_openbox_conf_dir}/DmDmDmdMdMdM_rc.xml" "${openbox_conf_dir}"
		echo "DmDmDmdMdMdM_rc.xml" > "${openbox_conf_dir}/rc_name"
	elif [ "$which_panel_MENU" == "tint2" ]; then
		if command -v jgmenu &> /dev/null
		then
			_jgmenu_="jgmenu|"
		fi
		which_MENU="$(rofi -no-config -no-lazy-grab -sep "|" -dmenu -i -p '' -no-click-to-exit \
		-theme "$rofi_style_dir"/launcher.rasi \
		<<< "${_jgmenu_}my_obmenu|bl_obmenu")"
		if [ "$which_MENU" == "jgmenu" ]; then
			cp -r "${lib_openbox_conf_dir}/bl-rc-jgmenu.xml" "${openbox_conf_dir}"
			echo "bl-rc-jgmenu.xml" > "${openbox_conf_dir}/rc_name"
			setbg -s --set-color=#18191A /usr/share/DmDmDmdMdMdM/images/wallpapers/default/default
		elif [ "$which_MENU" == "bl_obmenu" ]; then
			cp -r "${lib_openbox_conf_dir}/bl-rc-openbox.xml" "${openbox_conf_dir}"
			echo "bl-rc-openbox.xml" > "${openbox_conf_dir}/rc_name"
		elif [ "$which_MENU" == "my_obmenu" ]; then
			cp -r "${lib_openbox_conf_dir}/DmDmDmdMdMdM_rc.xml" "${openbox_conf_dir}"
			echo "DmDmDmdMdMdM_rc.xml" > "${openbox_conf_dir}/rc_name"
			echo "/.config/tint2/old.tint2rc" > $HOME/.config/tint2/tint2-sessionfile
		fi
	else
		which_panel_MENU="$default_panel"
		cp -r "${lib_openbox_conf_dir}/DmDmDmdMdMdM_rc.xml" "${openbox_conf_dir}"
		echo "DmDmDmdMdMdM_rc.xml" > "${openbox_conf_dir}/rc_name"
	fi
	
	echo "$which_panel_MENU" > ${_panel_name_path_}
}

panel_launcher() {
	_panel_name_=$(cat ${_panel_name_path_})
	
	## Notification Daemon
	dunst-session &

	# Start compositor
	picom-session &

	## Launch Plank
	#plank-session
		
	if [ "$_panel_name_" = "polybar" ]; then 
		# Start polybar
    	polybar-session 

		## Enable power management
		my_power_manager
		
		# Start volume control
		audio-session stop
		
		# Start network manager
		nm-applet-session stop		
		
		# Lauch xsettingsd daemon
		xfsettingsd-session stop
		
		# Start power manager
		xfce4-power-manager-session stop
		
	elif [ "$_panel_name_" =  "xfce4-panel" ]; then

		# Start xfce4-panel
    	xfce4-panel-session
    	
    	# Lauch xsettingsd daemon
		xfsettingsd-session

		# Start volume control
		audio-session
		
		# Start network manager
		nm-applet-session		
		
		# Start power manager
		xfce4-power-manager-session
		
		## Enable power management
		my_power_manager stop
		
	elif [ "$_panel_name_" =  "tint2" ]; then
		# Start volume control
		audio-session

		# Start network manager
		nm-applet-session	

		## Enable power management
		my_power_manager
		
		# panel - taskbar, system tray, battery, clock
		tint2-session

    	# Lauch xsettingsd daemon
		xfsettingsd-session stop

		# Start power manager
		xfce4-power-manager-session stop	
	fi 
}

panel_changer(){
	panel_name="$opt2"
	if [[ "$panel_name" == 'tint2' ]]; then
		echo 'tint2' > ${_panel_name_path_}
		panel_reload
	elif [[ "$panel_name" == 'polybar' ]]; then
		echo 'polybar' > ${_panel_name_path_}
		panel_reload 
	elif [[ "$panel_name" == 'xfce4-panel' ]]; then
		echo 'xfce4-panel' > ${_panel_name_path_}
		panel_reload
	fi
}

panel_reload(){
	_panel_name_=$(cat ${_panel_name_path_})
	polybar-session stop
	xfce4-panel-session stop
	tint2-session stop
	panel_launcher
}

case $opt in
		--picker) panel_picker ;;
		--launch) panel_launcher ;;
		--change) panel_changer ;;
		--reload) panel_reload ;;
esac
