#!/usr/bin/env bash
# Load current theme
. "/usr/share/my_stuff/lib/common/WM"
. "/usr/share/my_stuff/lib/common/rofi"
. "/usr/share/my_stuff/lib/common/polybar"

rofi_command="rofi -dmenu -theme ${rofi_style_dir}/RiceSelector.rasi"
rices_path="/usr/share/my_stuff/blob/polybar"
ROFI_STYLE="${ROFI_STYLE#/}"
# Variables to try to define the correct size of the images for your resolution
monitor_res=$(($(xdpyinfo | awk '/dimensions/{print $2}' | cut -d 'x' -f1) * 17 / $(xdpyinfo | awk '/resolution/{print $2}' | cut -d 'x' -f1)))
rofi_override="element-icon{size:${monitor_res}px;}"

# List themes in ani
mapfile -t list_of_ani_theme < <(find "${rices_path}/" -mindepth 1 -maxdepth 1 -type d -printf '%P\n' | sort)

selected_index=$(printf '%s\n' "${list_of_ani_theme[@]}" | awk -v cur="$ROFI_STYLE" '$0==cur {print NR-1; exit}')

# Show the rofi selection menu.
selected=$(
    for rice in "${list_of_ani_theme[@]}"; do
        echo -e "$rice\0icon\x1f${rices_path}/$rice/preview.jpg"
    done | $rofi_command -theme-str "$rofi_override" -selected-row "$selected_index"
)

# If a valid option was selected, write the value to the configuration file and change theme.
[[ -n "$selected" && "$selected" != "$ROFI_STYLE" ]] && style-manager --change "${selected}"
